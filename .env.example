# Server-side API credentials
TOUR_API_KEY=replace_with_tour_api_key
GOOGLE_PLACES_API_KEY=replace_with_google_places_api_key

# PASS identity verification (PortOne V2 + KG Inicis unified identity)
# Store/channel IDs are returned to the browser. Keep the API secret server-only.
PORTONE_STORE_ID=store-replace_with_portone_store_id
PORTONE_IDENTITY_CHANNEL_KEY=channel-key-replace_with_pass_channel_key
PORTONE_API_SECRET=replace_with_server_only_portone_v2_api_secret

# Optional request/cache tuning
GOOGLE_PLACES_DELAY_MS=150
GOOGLE_RATING_CACHE_DAYS=30
