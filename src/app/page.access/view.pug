                            div(class="course-calendar-picker")
                                div(class="calendar-nav")
                                    button(type="button", aria-label="이전 달", (click)="changeCourseDateMonth(-1)")
                                        i(class="fa-solid fa-chevron-left", aria-hidden="true")
                                    strong {{courseDateCalendarMonthLabel()}}
                                    button(type="button", aria-label="다음 달", (click)="changeCourseDateMonth(1)")
                                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                                div(class="course-calendar-grid", (pointermove)="previewCourseDatePointer($event)", (pointerup)="finishCourseDateDrag()", (pointerleave)="finishCourseDateDrag()", (pointercancel)="finishCourseDateDrag()")
                                    button(type="button", class="calendar-day", *ngFor="let day of courseDateCalendarDays()", [attr.data-course-date-key]="day.key", [class.muted]="!day.inMonth", [class.today]="day.isToday", [class.in-range]="day.inRange", [class.range-start]="day.rangeStart", [class.range-end]="day.rangeEnd", [class.selected]="day.selected", [attr.aria-label]="day.ariaLabel", (pointerdown)="startCourseDateDrag(day, $event)")
                                        span {{day.label}}
                    div(class="course-info-options")
