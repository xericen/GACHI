            div(class="filter-overview-list")
                button(type="button", class="filter-overview-option", (click)="openFilterSheetFromOverview('location')")
                    span(class="filter-overview-icon")
                        i(class="fa-solid fa-location-dot", aria-hidden="true")
                    span(class="filter-overview-copy")
                        strong 위치
                        small {{selectedFilters.location || '모든 지역'}}
                    i(class="fa-solid fa-chevron-right", aria-hidden="true")
                div(class="filter-overview-option filter-overview-move")
                    span(class="filter-overview-icon")
                        i(class="fa-solid fa-route", aria-hidden="true")
                    span(class="filter-overview-copy")
                        strong 이동
                        small {{getMoveFilterLabel()}}
                    div(class="filter-mode-grid", aria-label="이동 수단")
                        button(type="button", *ngFor="let mode of moveFilterOptions", [class.active]="selectedMoveFilter === mode.key", [attr.aria-pressed]="selectedMoveFilter === mode.key", (click)="selectMoveFilter(mode.key)")
                            i(class="fa-solid", [ngClass]="mode.icon", aria-hidden="true")
                            span {{mode.label}}
                button(type="button", class="filter-overview-option", (click)="openFilterSheetFromOverview('companion')")
                    span(class="filter-overview-icon")
                        i(class="fa-solid fa-user-group", aria-hidden="true")
                    span(class="filter-overview-copy")
                        strong 누구랑
                        small {{selectedFilters.companion || '전체'}}
                    i(class="fa-solid fa-chevron-right", aria-hidden="true")
            div(class="filter-overview-actions")
                button(type="button", class="overview-reset-button", [disabled]="!hasActiveFilters()", (click)="clearAllFilters()") 초기화
                button(type="button", class="overview-apply-button", (click)="closeFilterOverview()") 완료

        div(class="auth-gate-backdrop", *ngIf="authModalOpen", (click)="closeAuthModal()")
        section(class="auth-gate-modal", *ngIf="authModalOpen", role="dialog", aria-modal="true", [attr.aria-label]="authModalTitle()")
            div(class="auth-hero")
                span(class="auth-logo-box")
                    i(class="fa-solid fa-route", aria-hidden="true")
                h1 {{authModalTitle()}}
                p 로그인하면 저장한 코스, AI 대화 기록, 커뮤니티 기능을 이어서 사용할 수 있어요.
            div(class="auth-sheet")
                form(class="auth-form", (submit)="$event.preventDefault(); submitAuth()")
                    label
                        span 이메일
                        input(type="email", name="authEmail", autocomplete="email", [(ngModel)]="authForm.email", placeholder="name@example.com", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.email") {{authErrors.email}}
                    label(*ngIf="authMode === 'register'")
                        span 닉네임
                        input(type="text", name="authNickname", autocomplete="nickname", [(ngModel)]="authForm.nickname", placeholder="여행자", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.nickname") {{authErrors.nickname}}
                    label
                        span 비밀번호
                        input(type="password", name="authPassword", autocomplete="current-password", [(ngModel)]="authForm.password", placeholder="비밀번호 입력", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.password") {{authErrors.password}}
                    label(*ngIf="authMode === 'register'")
                        span 비밀번호 확인
                        input(type="password", name="authPasswordConfirm", autocomplete="new-password", [(ngModel)]="authForm.passwordConfirm", placeholder="비밀번호 확인", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.passwordConfirm") {{authErrors.passwordConfirm}}
                    div(class="server-error", *ngIf="authServerError") {{authServerError}}
                    button(type="submit", class="auth-primary", [disabled]="authSubmitting") {{authSubmitLabel()}}
                    button(type="button", class="auth-secondary", *ngIf="authMode === 'login'", [disabled]="authSubmitting", (click)="switchAuthMode('register')") 회원가입
                    button(type="button", class="auth-secondary", *ngIf="authMode === 'register'", [disabled]="authSubmitting", (click)="switchAuthMode('login')") 로그인으로 돌아가기
                    button(type="button", class="auth-guest-link", [disabled]="authSubmitting", (click)="closeAuthModal()") 다음에 할게요

        section(class="course-composer-screen", *ngIf="courseComposerOpen", role="dialog", aria-modal="true", [attr.aria-label]="courseComposerPlannerEdit ? 'AI 코스 수정' : '코스 제작'")
            div(class="course-screen-topbar")
                button(type="button", class="course-back-button", aria-label="뒤로", (click)="closeCourseComposer()")
                    i(class="fa-solid fa-chevron-left", aria-hidden="true")
                div
                    span {{courseComposerPlannerEdit ? 'AI 코스 수정' : '코스 제작'}}
                    h2 {{courseComposerPlannerEdit ? courseDraft.title : '새 여행 코스'}}
                    small(*ngIf="courseDraftSavedAt") 임시저장 {{courseDraftSavedAt}}
                button(type="button", class="course-save-icon course-draft-archive-button", *ngIf="courseBuilderStep === 'mode'", [class.active]="courseDraftArchiveOpen || hasSavedCourseDraft()", aria-label="코스 보관함", (click)="openCourseDraftArchive()")
                    i(class="fa-solid fa-box-archive", aria-hidden="true")
                    span(class="draft-archive-dot", *ngIf="hasSavedCourseDraft()")
                button(type="button", class="course-save-icon", *ngIf="courseBuilderStep !== 'mode' && !courseComposerPlannerEdit", aria-label="임시 저장", (click)="saveCourseDraft()")
