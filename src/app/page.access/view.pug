                                        button(type="submit")
                                            i(class="fa-solid fa-paper-plane", aria-hidden="true")
                                            span 등록

                    section(class="direct-chat-content", *ngIf="activeTab === 'chat' && chatContentTab === 'dm'", [class.room-open]="directRoomOpen")
