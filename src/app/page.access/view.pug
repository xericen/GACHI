                                    button(type="button", [class.active]="hasLikedCommunityPost(activeCommunityPost)", [disabled]="hasLikedCommunityPost(activeCommunityPost)", (click)="likeCommunityPost($event, activeCommunityPost)")
                                        i(class="fa-heart", [ngClass]="hasLikedCommunityPost(activeCommunityPost) ? 'fa-solid' : 'fa-regular'", aria-hidden="true")
                                        span 좋아요 {{activeCommunityPost.likes || 0}}
                                    span
