                            small {{place.area || place.address || place.category || '방문 장소'}}
                            input(type="text", [(ngModel)]="place.memo", aria-label="메모", (input)="updateCoursePlaceMemo()")
                            small(class="timeline-distance", *ngIf="index < courseBuilderPlaces.length - 1") {{courseSegmentDistanceLabel(index)}}
                        div(class="timeline-actions")
                            button(type="button", class="drag-handle", aria-label="순서 변경")
                                i(class="fa-solid fa-grip-vertical", aria-hidden="true")
                            button(type="button", class="remove-place", aria-label="삭제", (click)="removeCoursePlace(index)")
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                    button(type="button", class="add-place-dashed", (click)="focusCoursePlaceSearch()")
                        i(class="fa-solid fa-plus", aria-hidden="true")
                        span 지도에서 장소 추가
            div(class="course-action-bar", *ngIf="courseBuilderStep === 'places'")
                p(class="course-builder-error", *ngIf="courseBuilderError") {{courseBuilderError}}
                div(class="course-action-buttons")
                    button(type="button", class="course-step-back", (click)="courseComposerPlannerEdit ? closeCourseComposer() : backToCourseInfo()")
                        i(class="fa-solid", [ngClass]="courseComposerPlannerEdit ? 'fa-xmark' : 'fa-arrow-left'", aria-hidden="true")
                        span {{courseComposerPlannerEdit ? '취소' : '이전'}}
                    button(type="button", class="course-publish-button", *ngIf="!courseComposerPlannerEdit", (click)="openCoursePublishModal()")
                        i(class="fa-solid fa-paper-plane", aria-hidden="true")
                        span 코스 게시하기
                    button(type="button", class="course-publish-button course-edit-complete", *ngIf="courseComposerPlannerEdit", [disabled]="courseAiRebuilding", (click)="completePlannerCourseEdit()")
                        i(class="fa-solid", [ngClass]="courseAiRebuilding ? 'fa-spinner fa-spin' : 'fa-wand-magic-sparkles'", aria-hidden="true")
                        span {{courseAiRebuilding ? 'AI 재구성 중' : '변경 완료'}}

            div(class="course-publish-backdrop", *ngIf="coursePublishModalOpen", (click)="closeCoursePublishModal()")
            section(class="course-publish-modal", *ngIf="coursePublishModalOpen", role="dialog", aria-modal="true", aria-label="코스 게시 설정")
                div(class="publish-modal-head")
                    div
                        span 게시 설정
                        h3 코스 메타 정보
                    button(type="button", aria-label="닫기", (click)="closeCoursePublishModal()")
                        i(class="fa-solid fa-xmark", aria-hidden="true")
                div(class="publish-modal-body")
                    label
                        span 제목
                        input(type="text", [(ngModel)]="courseDraft.title", placeholder="예: 성수 감성 데이트 루트")
                    div(class="publish-grid")
                        label
                            span 카테고리
                            select(name="course_publish_category", [(ngModel)]="courseDraft.category")
                                option(value="여행") 여행
                                option(value="데이트") 데이트
                        label
                            span 대표 지역
                            input(type="text", [(ngModel)]="courseDraft.region", placeholder="서울 성수")
                    div(class="companion-segment", aria-label="동행 유형")
                        button(type="button", [class.active]="courseDraft.companionType === 'couple'", (click)="setCourseCompanionType('couple')") 연인
                        button(type="button", [class.active]="courseDraft.companionType === 'friend'", (click)="setCourseCompanionType('friend')") 친구
                        button(type="button", [class.active]="courseDraft.companionType === 'solo'", (click)="setCourseCompanionType('solo')") 혼자
                    div(class="course-info-field")
                        span 커버 이미지
                        div(class="course-cover-upload", [class.has-image]="courseDraft.photo")
                            label(class="course-cover-button")
                                i(class="fa-regular fa-image", aria-hidden="true")
                                span {{courseDraft.photoName || '사진 첨부'}}
                                input(type="file", accept="image/*", (change)="onCourseCoverFile($event)")
                            img(*ngIf="courseDraft.photo", [src]="courseDraft.photo", alt="")
                    label
                        span 코스 설명
                        textarea(rows="3", [(ngModel)]="courseDraft.description", placeholder="코스 분위기, 이동 팁, 추천 이유를 적어주세요.")
                    button(type="button", class="companion-toggle", [class.active]="courseDraft.companionEnabled", (click)="toggleCourseCompanion()")
                        i(class="fa-solid", [ngClass]="courseDraft.companionEnabled ? 'fa-toggle-on' : 'fa-toggle-off'", aria-hidden="true")
                        span 동행 모집하기
                    div(class="companion-compose-fields", *ngIf="courseDraft.companionEnabled")
                        div(class="compose-grid")
                            label
                                span 여행 날짜
                                input(type="text", [(ngModel)]="courseDraft.companionDate", placeholder="7.12 토")
                            label
                                span 모집 인원
                                input(type="number", min="1", max="8", [(ngModel)]="courseDraft.companionCapacity")
                        label
                            span 간단한 소개
                            textarea(rows="2", [(ngModel)]="courseDraft.companionIntro", placeholder="함께할 여행자에게 보여줄 소개를 적어주세요.")
                    p(class="course-builder-error", *ngIf="courseBuilderError") {{courseBuilderError}}
                div(class="publish-modal-actions")
                    button(type="button", class="compose-secondary", (click)="closeCoursePublishModal()") 취소
                    button(type="button", class="compose-primary", [disabled]="coursePublishSubmitting", (click)="submitCoursePublish()") {{coursePublishSubmitting ? '게시 중' : '게시 완료'}}

        div(class="composer-backdrop", *ngIf="communityComposerOpen", (click)="closeCommunityComposer()")
        section(class="course-composer-sheet community-composer-sheet", *ngIf="communityComposerOpen", role="dialog", aria-modal="true", aria-label="커뮤니티 글 작성")
            div(class="composer-sheet-head")
                div
                    span 커뮤니티 작성
                    h2 {{communityDraft.kind === 'question' ? '질문글 올리기' : '글쓰기'}}
                button(type="button", aria-label="닫기", [disabled]="communityPublishSubmitting", (click)="closeCommunityComposer()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")
            form(class="course-compose-form community-compose-form", (submit)="$event.preventDefault(); publishCommunityPost()")
                div(class="community-type-toggle", aria-label="글 종류")
                    button(type="button", [class.active]="communityDraft.kind === 'post'", (click)="setCommunityDraftKind('post')")
                        i(class="fa-regular fa-pen-to-square", aria-hidden="true")
                        span 일반글
                    button(type="button", [class.active]="communityDraft.kind === 'question'", (click)="setCommunityDraftKind('question')")
                        i(class="fa-regular fa-circle-question", aria-hidden="true")
                        span 질문글
                label(*ngIf="communityDraft.kind !== 'question'")
                    span 주제
                    select(name="communityTopic", [(ngModel)]="communityDraft.topic")
                        option(*ngFor="let topic of communityTopics", [value]="topic.key", [disabled]="communityDraft.kind === 'post' && topic.key === 'question'") {{topic.label}}
                label
                    span 제목
                    input(type="text", name="communityTitle", [(ngModel)]="communityDraft.title", placeholder="예: 제주 서쪽 2박 코스 질문")
                label
                    span 본문
                    textarea(name="communityBody", [(ngModel)]="communityDraft.body", rows="5", placeholder="블로그 글처럼 여행 경험, 질문, 팁을 자유롭게 적어주세요.")
                div(class="community-relation-toggle", aria-label="여행지 관련 여부")
                    button(type="button", [class.active]="communityDraft.hasDestination", (click)="setCommunityDraftDestination(true)")
                        i(class="fa-solid fa-location-dot", aria-hidden="true")
                        span 여행지 관련
                    button(type="button", [class.active]="!communityDraft.hasDestination", (click)="setCommunityDraftDestination(false)")
                        i(class="fa-regular fa-message", aria-hidden="true")
                        span 일반 주제
                div(class="compose-grid", *ngIf="communityDraft.hasDestination")
                    label
                        span 여행지
                        input(type="text", name="communityDestination", [(ngModel)]="communityDraft.destination", placeholder="서울 성수, 제주 애월")
                    label
                        span 장소
                        input(type="text", name="communityPlace", [(ngModel)]="communityDraft.place", placeholder="카페, 숙소, 전시관")
                div(class="community-tool-grid")
                    div(class="community-photo-field")
                        span 사진
                        div(class="community-photo-actions")
                            label(class="community-photo-button")
                                input(type="file", accept="image/*", aria-label="사진 첨부", (change)="handleCommunityPhotoUpload($event)")
                                i(class="fa-regular fa-image", aria-hidden="true")
                                span 사진 첨부
                            label(class="community-photo-button")
                                input(type="file", accept="image/*", capture="environment", aria-label="사진 촬영", (change)="handleCommunityPhotoUpload($event)")
                                i(class="fa-solid fa-camera", aria-hidden="true")
                                span 촬영
                        div(class="community-photo-preview", *ngIf="communityDraft.photo")
                            img(*ngIf="communityPhotoIsImage(communityDraft.photo)", [src]="communityDraft.photo", alt="첨부 사진 미리보기")
                            span {{communityDraft.photoName || '첨부 사진'}}
                            button(type="button", aria-label="사진 삭제", (click)="clearCommunityPhoto()")
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                    div(class="community-poll-builder", *ngIf="communityDraft.kind === 'question'")
                        div(class="community-tool-head")
                            span 투표
                            small 질문글에서 선택지를 하나씩 추가하세요.
                        div(class="community-option-list", *ngIf="communityDraftPollOptions().length > 0")
                            div(class="community-option-chip", *ngFor="let option of communityDraftPollOptions()")
                                span {{option}}
                                button(type="button", [attr.aria-label]="option + ' 삭제'", (click)="removeCommunityPollOption(option)")
                                    i(class="fa-solid fa-xmark", aria-hidden="true")
                        div(class="community-option-add")
                            input(type="text", name="communityPollInput", [(ngModel)]="communityDraft.pollInput", placeholder="예: 제주 애월 카페", (keydown)="handleCommunityPollKeydown($event)")
                            button(type="button", aria-label="투표 선택지 추가", (click)="addCommunityPollOption($event)")
                                i(class="fa-solid fa-plus", aria-hidden="true")
                    div(class="community-tag-editor")
                        div(class="community-tool-head")
                            span 태그
                            small #여행지 입력 후 추가하면 태그로 표시됩니다.
                        div(class="community-tag-list", *ngIf="communityDraftTags().length > 0")
                            button(type="button", class="community-tag-chip", *ngFor="let tag of communityDraftTags()", [attr.aria-label]="tag + ' 태그 삭제'", (click)="removeCommunityTag(tag)")
                                span {{'#' + tag}}
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                        div(class="community-option-add")
                            input(type="text", name="communityTagInput", [(ngModel)]="communityDraft.tagInput", placeholder="#여행지", (keydown)="handleCommunityTagKeydown($event)", (blur)="addCommunityTagFromInput($event)")
                            button(type="button", aria-label="태그 추가", (click)="addCommunityTagFromInput($event)")
                                i(class="fa-solid fa-plus", aria-hidden="true")
                div(class="compose-actions")
                    button(type="button", class="compose-secondary", [disabled]="communityPublishSubmitting", (click)="closeCommunityComposer()") 취소
                    button(type="submit", class="compose-primary", [disabled]="communityPublishSubmitting")
                        i(class="fa-solid", [ngClass]="communityPublishSubmitting ? 'fa-spinner fa-spin' : 'fa-paper-plane'", aria-hidden="true")
                        span {{communityPublishSubmitting ? '올리는 중' : '올리기'}}

        div(class="sheet-backdrop", *ngIf="activeFilterKey", (click)="closeFilterSheet()")
        section(class="filter-dialog", *ngIf="activeFilter() as filter", role="dialog", aria-modal="true", [attr.aria-label]="getSheetTitle(filter)")
            div(class="sheet-head", [class.has-back]="shouldShowFilterBack(filter)")
                button(type="button", class="sheet-back-button", *ngIf="shouldShowFilterBack(filter)", aria-label="조건 선택으로 돌아가기", (click)="backToFilterOverview()")
                    i(class="fa-solid fa-chevron-left", aria-hidden="true")
                div(class="sheet-title")
                    span {{filter.label}}
                    h2 {{getSheetTitle(filter)}}
                button(type="button", class="sheet-close-button", aria-label="닫기", (click)="closeFilterSheet()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")

            div(class="sheet-options", *ngIf="filter.key === 'companion'")
                button(type="button", class="sheet-option", *ngFor="let option of filter.options", [class.active]="selectedFilters[filter.key] === option", (click)="selectCondition(filter.key, option)")
                    span {{option}}
                    i(*ngIf="selectedFilters[filter.key] === option", class="fa-solid fa-check", aria-hidden="true")

            div(class="calendar-picker", *ngIf="filter.key === 'schedule'")
                div(class="calendar-nav")
                    button(type="button", aria-label="이전 달", (click)="changeCalendarMonth(-1)")
                        i(class="fa-solid fa-chevron-left", aria-hidden="true")
                    strong {{calendarMonthLabel}}
                    button(type="button", aria-label="다음 달", (click)="changeCalendarMonth(1)")
                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                div(class="calendar-weekdays")
                    span(*ngFor="let weekday of weekdays") {{weekday}}
                div(class="calendar-grid", (pointermove)="previewSchedulePointer($event)", (pointerup)="finishSchedulePointer($event)", (pointerleave)="finishSchedulePointer($event)", (pointercancel)="cancelScheduleDrag()")
                    button(type="button", class="calendar-day", *ngFor="let day of calendarDays", [attr.data-date-key]="day.key", [class.muted]="!day.inMonth", [class.today]="day.isToday", [class.in-range]="isScheduleDayInRange(day)", [class.range-start]="isScheduleRangeStart(day)", [class.range-end]="isScheduleRangeEnd(day)", [class.selected]="isScheduleDaySelected(day)", [attr.aria-label]="day.ariaLabel", (pointerdown)="startScheduleDrag(day, $event)", (click)="selectScheduleDay(day)")
                        span {{day.label}}
                div(class="date-range-summary", *ngIf="selectedFilters.schedule")
                    span 선택
                    strong {{selectedFilters.schedule}}
                    button(type="button", aria-label="날짜 초기화", (click)="clearSchedule()")
                        i(class="fa-solid fa-rotate-left", aria-hidden="true")

            div(class="location-picker", *ngIf="filter.key === 'location'")
                div(class="location-regions")
                    button(type="button", class="location-region-button", *ngFor="let region of locationGroups", [class.active]="selectedLocationRegion === region.name", (click)="selectLocationRegion(region)")
                        span {{region.name}}
                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                div(class="location-areas")
                    button(type="button", class="location-area-button", *ngFor="let area of activeLocationAreas()", [class.active]="isLocationAreaSelected(area)", (click)="selectLocationArea(area)")
                        span {{area.label}}
                        i(*ngIf="isLocationAreaSelected(area)", class="fa-solid fa-check", aria-hidden="true")

        div(class="map-sheet-backdrop", *ngIf="activeTab === 'map' && mapContentTab === 'map' && selectedMapSpot()", (click)="closeMapSpotSheet()")
        section(class="map-place-sheet", *ngIf="activeTab === 'map' && mapContentTab === 'map' && selectedMapSpot() as spot", role="dialog", aria-modal="true", [attr.aria-label]="spot.name + ' 상세'")
            div(class="place-photo", [ngClass]="spot.photoClass")
                span {{spot.kind}}
            div(class="place-detail")
                div(class="place-head")
                    div
                        span {{spot.order}}번째 코스
                        h2 {{spot.name}}
                    button(type="button", aria-label="닫기", (click)="closeMapSpotSheet()")
                        i(class="fa-solid fa-xmark", aria-hidden="true")
                p {{spot.description}}
                div(class="place-meta")
                    span
                        i(class="fa-solid fa-star", aria-hidden="true")
                        | {{spot.rating}}
                    span
                        i(class="fa-regular fa-clock", aria-hidden="true")
                        | {{spot.hours}}
                    span
                        i(class="fa-solid", [ngClass]="travelMode === 'walk' ? 'fa-person-walking' : 'fa-car-side'", aria-hidden="true")
                        | {{getSpotTravelTime(spot)}}
                button(type="button", class="visit-cta", [class.done]="spot.visited", (click)="toggleVisit(spot, $event)")
                    i(class="fa-solid", [ngClass]="spot.visited ? 'fa-check' : 'fa-location-dot'", aria-hidden="true")
                    span {{spot.visited ? '도착 완료' : '여기 도착했어요'}}
