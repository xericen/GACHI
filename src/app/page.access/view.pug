                                            span {{option}}
                                            em {{communityPollPercent(post, option)}}%
                                    div(class="community-tags", *ngIf="post.tags && post.tags.length")
                                        span(*ngFor="let tag of post.tags.slice(0, 4)") {{'#' + tag}}
