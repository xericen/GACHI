                            small {{post.category || '커뮤니티'}} · {{post.createdLabel || '방금'}}
                    button(type="button", class="community-delete-button", [disabled]="communityDeleteSubmittingId === post.id", [attr.aria-label]="post.title + ' 삭제'", (click)="deleteCommunityPost($event, post)")
                        i(class="fa-solid", [ngClass]="communityDeleteSubmittingId === post.id ? 'fa-spinner fa-spin' : 'fa-trash-can'", aria-hidden="true")
            div(class="course-draft-archive-empty", *ngIf="!communityArchiveLoading && communityArchivePosts.length === 0")
                i(class="fa-regular fa-folder-open", aria-hidden="true")
                strong 내가 쓴 글이 없어요
                span 커뮤니티에서 글을 올리면 여기에 모입니다.

        div(class="sheet-backdrop", *ngIf="filterOverviewOpen", (click)="closeFilterOverview()")
        section(class="filter-dialog filter-overview-dialog", *ngIf="filterOverviewOpen", role="dialog", aria-modal="true", aria-label="필터")
            div(class="sheet-head")
                div
                    span 필터
                    h2 조건 선택
                button(type="button", aria-label="닫기", (click)="closeFilterOverview()")
