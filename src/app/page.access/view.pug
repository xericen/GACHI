                                button(type="submit", aria-label="보내기", [disabled]="!canSendChat()")
                                    i(class="fa-solid", [ngClass]="isChatSending ? 'fa-spinner fa-spin' : 'fa-paper-plane'", aria-hidden="true")

                    section(class="community-content chat-community-content", *ngIf="activeTab === 'home' && homeContentTab === 'community'")
                        div(class="community-list-view", *ngIf="!activeCommunityPost")
