                                    button(type="button", class="community-poll-option", *ngFor="let option of activeCommunityPost.poll.options", [class.selected]="communityPollOptionSelected(activeCommunityPost, option)", [disabled]="hasVotedCommunityPoll(activeCommunityPost)", (click)="voteCommunityPoll(activeCommunityPost, option)")
                                        span {{option}}
                                        em {{communityPollPercent(activeCommunityPost, option)}}%
                                div(class="community-tags", *ngIf="activeCommunityPost.tags && activeCommunityPost.tags.length")
                                    span(*ngFor="let tag of activeCommunityPost.tags") {{'#' + tag}}
