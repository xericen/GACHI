                                    span(class="zenly-pin-shape")
                            ng-container(*ngIf="zenlyLayerTab === 'signals'")
                                button(type="button", class="zenly-pin-marker signal", *ngFor="let signal of zenlySignalMarkers()", [ngClass]="'level-' + zenlyMarkerLevel(signal)", [class.active]="isZenlySignalSelected(signal)", [style.left]="signal.displayPosition.x + '%'", [style.top]="signal.displayPosition.y + '%'", [attr.data-signal-id]="signal.id", [attr.aria-label]="signal.message", (mousedown)="selectZenlySignal(signal, $event)", (touchstart)="selectZenlySignal(signal, $event)", (click)="selectZenlySignal(signal, $event)")
                                    span(class="zenly-pin-shape")
                            button(type="button", class="zenly-summary-bar", (click)="openZenlySummary($event)")
