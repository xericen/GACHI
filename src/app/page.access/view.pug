                            div(class="planner-map-modal", *ngIf="plannerMapExpanded", role="dialog", aria-modal="true", aria-labelledby="plannerMapModalTitle")
                                button(type="button", class="planner-map-modal-backdrop", aria-label="지도 닫기", (click)="closePlannerMap()")
                                section(class="planner-map-dialog")
                                    header
                                        div
                                            strong(id="plannerMapModalTitle") 실제 장소 동선
                                            small {{plannerRouteSource}}
