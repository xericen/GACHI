                                                i(class="fa-solid fa-location-dot", aria-hidden="true")
                                                | {{communityPostLocationLabel(post)}}
                                        div(class="community-meta")
                                            span
                                                i(class="fa-regular fa-eye", aria-hidden="true")
                                                | {{communityPostViews(post)}}
                                            button(type="button", aria-label="좋아요", [class.active]="hasLikedCommunityPost(post)", [disabled]="hasLikedCommunityPost(post)", (click)="likeCommunityPost($event, post)")
                                                i(class="fa-heart", [ngClass]="hasLikedCommunityPost(post) ? 'fa-solid' : 'fa-regular'", aria-hidden="true")
                                                | {{post.likes}}
                                            button(type="button", aria-label="댓글 보기", (click)="$event.stopPropagation(); openCommunityPost(post, true)")
                                                i(class="fa-regular fa-comment", aria-hidden="true")
                                                | {{post.comments}}
                                            span(*ngIf="post.votes")
                                                i(class="fa-solid fa-square-poll-vertical", aria-hidden="true")
                                                | {{post.votes}}
