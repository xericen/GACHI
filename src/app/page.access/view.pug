                            input(type="text", class="course-builder-entry-input", name="course_ai_region", [value]="courseDraft.region", placeholder="서울 성수", autocomplete="off", inputmode="search", (focus)="openCourseRegionSearch()", (input)="onCourseRegionInput($event)")
                            div(class="course-region-suggestions", *ngIf="courseRegionSearchOpen && courseRegionMatches().length > 0")
                                button(type="button", *ngFor="let region of courseRegionMatches()", (click)="selectCourseRegionSuggestion(region)")
                                    strong {{region.area || region.label}}
                                    small {{region.label}}
                        div(class="course-info-field course-date-field")
