        nav(class="bottom-tabs", aria-label="하단 탭")
            button(type="button", *ngFor="let tab of tabs", [class.active]="activeTab === tab.key", [attr.aria-selected]="activeTab === tab.key", (click)="selectTab(tab.key)")
                i([ngClass]="[tab.iconStyle || 'fa-solid', tab.icon]", aria-hidden="true")
                span {{tab.label}}

        div(class="save-hint-toast", *ngIf="saveHintVisible", role="status", aria-live="polite")
            i(class="fa-solid fa-circle-info", aria-hidden="true")
            span {{saveHintMessage}}

        div(class="course-draft-archive-backdrop", *ngIf="courseDraftArchiveOpen", (click)="closeCourseDraftArchive()")
        section(class="course-draft-archive-sheet", *ngIf="courseDraftArchiveOpen", role="dialog", aria-modal="true", aria-label="코스 보관함")
            div(class="sheet-head")
                div
                    span 코스 보관함
                    h2 임시저장한 코스
                button(type="button", aria-label="닫기", (click)="closeCourseDraftArchive()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")
            div(class="course-draft-archive-body", *ngIf="hasSavedCourseDraft()")
                button(type="button", class="course-draft-archive-card", (click)="loadSavedCourseDraft()")
                    span(class="archive-card-icon")
                        i(class="fa-solid fa-route", aria-hidden="true")
                    span(class="archive-card-copy")
                        strong {{savedCourseDraftTitle()}}
                        small {{savedCourseDraftMeta()}}
                    em(*ngIf="savedCourseDraftTime()") {{savedCourseDraftTime()}}
                    i(class="fa-solid fa-chevron-right", aria-hidden="true")
            div(class="course-draft-archive-empty", *ngIf="!hasSavedCourseDraft()")
                i(class="fa-regular fa-folder-open", aria-hidden="true")
                strong 저장된 코스가 없어요
                span 코스 제작 화면에서 임시 저장을 누르면 여기에 보관됩니다.

        div(class="course-draft-archive-backdrop", *ngIf="communityArchiveOpen", (click)="closeCommunityArchive()")
        section(class="course-draft-archive-sheet community-archive-sheet", *ngIf="communityArchiveOpen", role="dialog", aria-modal="true", aria-label="커뮤니티 보관함")
            div(class="sheet-head")
                div
                    span 보관함
                    h2 내가 쓴 글
                button(type="button", aria-label="닫기", [disabled]="!!communityDeleteSubmittingId", (click)="closeCommunityArchive()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")
            div(class="course-draft-archive-empty", *ngIf="communityArchiveLoading")
                i(class="fa-solid fa-spinner fa-spin", aria-hidden="true")
                strong 불러오는 중
                span 내가 쓴 글을 확인하고 있어요.
            div(class="community-archive-list", *ngIf="!communityArchiveLoading && communityArchivePosts.length > 0")
                article(class="community-archive-card", *ngFor="let post of communityArchivePosts")
                    button(type="button", class="community-archive-open", (click)="openArchivedCommunityPost(post)")
                        span(class="archive-card-icon")
                            i(class="fa-regular", [ngClass]="post.kind === 'question' ? 'fa-circle-question' : 'fa-pen-to-square'", aria-hidden="true")
                        span(class="archive-card-copy")
                            strong {{post.title}}
                            small {{post.category || '커뮤니티'}} · {{post.createdLabel || '방금'}}
                    button(type="button", class="community-delete-button", [disabled]="communityDeleteSubmittingId === post.id", [attr.aria-label]="post.title + ' 삭제'", (click)="deleteCommunityPost($event, post)")
                        i(class="fa-solid", [ngClass]="communityDeleteSubmittingId === post.id ? 'fa-spinner fa-spin' : 'fa-trash-can'", aria-hidden="true")
            div(class="course-draft-archive-empty", *ngIf="!communityArchiveLoading && communityArchivePosts.length === 0")
                i(class="fa-regular fa-folder-open", aria-hidden="true")
                strong 내가 쓴 글이 없어요
                span 커뮤니티에서 글을 올리면 여기에 모입니다.

        div(class="sheet-backdrop", *ngIf="filterOverviewOpen", (click)="closeFilterOverview()")
        section(class="filter-dialog filter-overview-dialog", *ngIf="filterOverviewOpen", role="dialog", aria-modal="true", aria-label="필터")
            div(class="sheet-head")
                div
                    span 필터
                    h2 조건 선택
                button(type="button", aria-label="닫기", (click)="closeFilterOverview()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")

            div(class="filter-overview-list")
                button(type="button", class="filter-overview-option", (click)="openFilterSheetFromOverview('location')")
                    span(class="filter-overview-icon")
                        i(class="fa-solid fa-location-dot", aria-hidden="true")
                    span(class="filter-overview-copy")
                        strong 위치
                        small {{selectedFilters.location || '모든 지역'}}
                    i(class="fa-solid fa-chevron-right", aria-hidden="true")
                div(class="filter-overview-option filter-overview-move")
                    span(class="filter-overview-icon")
                        i(class="fa-solid fa-route", aria-hidden="true")
                    span(class="filter-overview-copy")
                        strong 이동
                        small {{getMoveFilterLabel()}}
                    div(class="filter-mode-grid", aria-label="이동 수단")
                        button(type="button", *ngFor="let mode of moveFilterOptions", [class.active]="selectedMoveFilter === mode.key", [attr.aria-pressed]="selectedMoveFilter === mode.key", (click)="selectMoveFilter(mode.key)")
                            i(class="fa-solid", [ngClass]="mode.icon", aria-hidden="true")
                            span {{mode.label}}
                button(type="button", class="filter-overview-option", (click)="openFilterSheetFromOverview('companion')")
                    span(class="filter-overview-icon")
                        i(class="fa-solid fa-user-group", aria-hidden="true")
                    span(class="filter-overview-copy")
                        strong 누구랑
                        small {{selectedFilters.companion || '전체'}}
                    i(class="fa-solid fa-chevron-right", aria-hidden="true")
            div(class="filter-overview-actions")
                button(type="button", class="overview-reset-button", [disabled]="!hasActiveFilters()", (click)="clearAllFilters()") 초기화
                button(type="button", class="overview-apply-button", (click)="closeFilterOverview()") 완료

        div(class="auth-gate-backdrop", *ngIf="authModalOpen", (click)="closeAuthModal()")
        section(class="auth-gate-modal", *ngIf="authModalOpen", role="dialog", aria-modal="true", [attr.aria-label]="authModalTitle()")
            div(class="auth-hero")
                span(class="auth-logo-box")
                    i(class="fa-solid fa-route", aria-hidden="true")
                h1 {{authModalTitle()}}
                p 로그인하면 저장한 코스, AI 대화 기록, 커뮤니티 기능을 이어서 사용할 수 있어요.
            div(class="auth-sheet")
                form(class="auth-form", (submit)="$event.preventDefault(); submitAuth()")
                    label
                        span 이메일
                        input(type="email", name="authEmail", autocomplete="email", [(ngModel)]="authForm.email", placeholder="name@example.com", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.email") {{authErrors.email}}
                    label(*ngIf="authMode === 'register'")
                        span 닉네임
                        input(type="text", name="authNickname", autocomplete="nickname", [(ngModel)]="authForm.nickname", placeholder="여행자", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.nickname") {{authErrors.nickname}}
                    label
                        span 비밀번호
                        input(type="password", name="authPassword", autocomplete="current-password", [(ngModel)]="authForm.password", placeholder="비밀번호 입력", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.password") {{authErrors.password}}
                    label(*ngIf="authMode === 'register'")
                        span 비밀번호 확인
                        input(type="password", name="authPasswordConfirm", autocomplete="new-password", [(ngModel)]="authForm.passwordConfirm", placeholder="비밀번호 확인", [disabled]="authSubmitting")
                        small(class="field-error", *ngIf="authErrors.passwordConfirm") {{authErrors.passwordConfirm}}
                    div(class="server-error", *ngIf="authServerError") {{authServerError}}
                    button(type="submit", class="auth-primary", [disabled]="authSubmitting") {{authSubmitLabel()}}
                    button(type="button", class="auth-secondary", *ngIf="authMode === 'login'", [disabled]="authSubmitting", (click)="switchAuthMode('register')") 회원가입
                    button(type="button", class="auth-secondary", *ngIf="authMode === 'register'", [disabled]="authSubmitting", (click)="switchAuthMode('login')") 로그인으로 돌아가기
                    button(type="button", class="auth-guest-link", [disabled]="authSubmitting", (click)="closeAuthModal()") 다음에 할게요

        section(class="course-composer-screen", *ngIf="courseComposerOpen", role="dialog", aria-modal="true", [attr.aria-label]="courseComposerPlannerEdit ? 'AI 코스 수정' : '코스 제작'")
            div(class="course-screen-topbar")
                button(type="button", class="course-back-button", aria-label="뒤로", (click)="closeCourseComposer()")
                    i(class="fa-solid fa-chevron-left", aria-hidden="true")
                div
                    span {{courseComposerPlannerEdit ? 'AI 코스 수정' : '코스 제작'}}
                    h2 {{courseComposerPlannerEdit ? courseDraft.title : '새 여행 코스'}}
                    small(*ngIf="courseDraftSavedAt") 임시저장 {{courseDraftSavedAt}}
                button(type="button", class="course-save-icon course-draft-archive-button", *ngIf="courseBuilderStep === 'mode'", [class.active]="courseDraftArchiveOpen || hasSavedCourseDraft()", aria-label="코스 보관함", (click)="openCourseDraftArchive()")
                    i(class="fa-solid fa-box-archive", aria-hidden="true")
                    span(class="draft-archive-dot", *ngIf="hasSavedCourseDraft()")
                button(type="button", class="course-save-icon", *ngIf="courseBuilderStep !== 'mode' && !courseComposerPlannerEdit", aria-label="임시 저장", (click)="saveCourseDraft()")
                    i(class="fa-regular fa-floppy-disk", aria-hidden="true")
            section(class="course-mode-step", *ngIf="courseBuilderStep === 'mode'")
                div(class="course-mode-section")
                    div(class="builder-section-head")
                        div
                            span 코스 제작
                            h3 제작 방식 선택
                    div(class="course-mode-options")
                        button(type="button", class="course-mode-card", (click)="selectCourseBuilderMode('manual')")
                            i(class="fa-solid fa-pen-to-square", aria-hidden="true")
                            strong 직접 만들기
                            span 장소를 직접 담기
                        button(type="button", class="course-mode-card", (click)="selectCourseBuilderMode('ai')")
                            i(class="fa-solid fa-wand-magic-sparkles", aria-hidden="true")
                            strong AI 추천 받기
                            span 조건에 맞춘 코스 선택
            nav(class="course-builder-stepper", *ngIf="courseBuilderStep !== 'mode' && !courseComposerPlannerEdit", aria-label="코스 제작 단계")
                button(type="button", [class.active]="courseBuilderStep === 'info' || courseBuilderStep === 'ai'", [class.done]="courseBuilderMode === 'ai' || courseInfoStepComplete()", (click)="backToCourseInfo()")
                    span 1
                    strong {{courseBuilderStepOneLabel()}}
                button(type="button", [class.active]="courseBuilderStep === 'places'", [class.done]="courseBuilderPlaces.length > 0", (click)="setCourseBuilderStep('places')")
                    span 2
                    strong 장소 구성
            section(class="course-info-step course-ai-step", *ngIf="courseBuilderStep === 'ai'")
                div(class="course-info-section")
                    div(class="builder-section-head")
                        div
                            span AI 추천
                            h3 조건 입력
                    div(class="course-info-grid")
                        div(class="course-info-field course-region-field")
                            span 어디로
                            input(type="text", class="course-builder-entry-input", name="course_ai_region", [value]="courseDraft.region", placeholder="서울 성수", autocomplete="off", inputmode="search", (focus)="openCourseRegionSearch()", (input)="onCourseRegionInput($event)")
                            div(class="course-region-suggestions", *ngIf="courseRegionSearchOpen && courseRegionMatches().length > 0")
                                button(type="button", *ngFor="let region of courseRegionMatches()", (click)="selectCourseRegionSuggestion(region)")
                                    strong {{region.area || region.label}}
                                    small {{region.label}}
                        div(class="course-info-field course-date-field")
                            span 언제
                            div(class="course-calendar-picker")
                                div(class="calendar-nav")
                                    button(type="button", aria-label="이전 달", (click)="changeCourseDateMonth(-1)")
                                        i(class="fa-solid fa-chevron-left", aria-hidden="true")
                                    strong {{courseDateCalendarMonthLabel()}}
                                    button(type="button", aria-label="다음 달", (click)="changeCourseDateMonth(1)")
                                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                                div(class="course-calendar-grid", (pointermove)="previewCourseDatePointer($event)", (pointerup)="finishCourseDateDrag()", (pointerleave)="finishCourseDateDrag()", (pointercancel)="finishCourseDateDrag()")
                                    button(type="button", class="calendar-day", *ngFor="let day of courseDateCalendarDays()", [attr.data-course-date-key]="day.key", [class.muted]="!day.inMonth", [class.today]="day.isToday", [class.in-range]="day.inRange", [class.range-start]="day.rangeStart", [class.range-end]="day.rangeEnd", [class.selected]="day.selected", [attr.aria-label]="day.ariaLabel", (pointerdown)="startCourseDateDrag(day, $event)")
                                        span {{day.label}}
                    div(class="course-info-options")
                        span(class="course-option-label") 누구와
                        div(class="companion-segment", aria-label="누구와")
                            button(type="button", [class.active]="courseDraft.companionType === 'couple'", (click)="setCourseCompanionType('couple')") 연인
                            button(type="button", [class.active]="courseDraft.companionType === 'friend'", (click)="setCourseCompanionType('friend')") 친구
                            button(type="button", [class.active]="courseDraft.companionType === 'solo'", (click)="setCourseCompanionType('solo')") 혼자
                    label(class="course-info-field")
                        span 원하는 분위기
                        input(type="text", name="course_ai_mood", [(ngModel)]="courseAiMood", placeholder="조용한 카페, 산책, 사진")
                    div(class="course-ai-option-list", *ngIf="courseAiReady()")
                        button(type="button", class="course-ai-card", *ngFor="let option of courseAiOptions()", (click)="applyAiCourseOption(option)")
                            strong {{option.title}}
                            span {{option.summary}}
                            small {{option.places.join(' → ')}}
                    div(class="course-ai-empty", *ngIf="!courseAiReady()") 어디로, 언제 갈지 입력해주세요
                    p(class="course-builder-error", *ngIf="courseBuilderError") {{courseBuilderError}}
                div(class="course-info-actions")
                    button(type="button", class="compose-secondary", (click)="resetCourseBuilderMode()") 방식 변경
                    button(type="button", class="compose-primary", (click)="selectCourseBuilderMode('manual')") 직접 만들기
            section(class="course-info-step", *ngIf="courseBuilderStep === 'info'")
                div(class="course-info-section")
                    div(class="builder-section-head")
                        div
                            span 기본 정보
                            h3 코스 등록 정보
                    label(class="course-info-field")
                        span 여행 제목
                        input(type="text", class="course-builder-entry-input course-title-input", name="course_manual_title", [(ngModel)]="courseDraft.title", placeholder="예: 성수 감성 데이트 루트", autocomplete="off")
                    div(class="course-info-grid")
                        div(class="course-info-field course-region-field")
                            span 어디로
                            input(type="text", name="course_manual_region", [value]="courseDraft.region", placeholder="서울 성수", autocomplete="off", inputmode="search", (focus)="openCourseRegionSearch()", (input)="onCourseRegionInput($event)")
                            div(class="course-region-suggestions", *ngIf="courseRegionSearchOpen && courseRegionMatches().length > 0")
                                button(type="button", *ngFor="let region of courseRegionMatches()", (click)="selectCourseRegionSuggestion(region)")
                                    strong {{region.area || region.label}}
                                    small {{region.label}}
                        div(class="course-info-field course-date-field")
                            span 언제
                            div(class="course-calendar-picker")
                                div(class="calendar-nav")
                                    button(type="button", aria-label="이전 달", (click)="changeCourseDateMonth(-1)")
                                        i(class="fa-solid fa-chevron-left", aria-hidden="true")
                                    strong {{courseDateCalendarMonthLabel()}}
                                    button(type="button", aria-label="다음 달", (click)="changeCourseDateMonth(1)")
                                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                                div(class="course-calendar-grid", (pointermove)="previewCourseDatePointer($event)", (pointerup)="finishCourseDateDrag()", (pointerleave)="finishCourseDateDrag()", (pointercancel)="finishCourseDateDrag()")
                                    button(type="button", class="calendar-day", *ngFor="let day of courseDateCalendarDays()", [attr.data-course-date-key]="day.key", [class.muted]="!day.inMonth", [class.today]="day.isToday", [class.in-range]="day.inRange", [class.range-start]="day.rangeStart", [class.range-end]="day.rangeEnd", [class.selected]="day.selected", [attr.aria-label]="day.ariaLabel", (pointerdown)="startCourseDateDrag(day, $event)")
                                        span {{day.label}}
                    div(class="course-info-grid")
                        label(class="course-info-field")
                            span 카테고리
                            select(name="course_manual_category", [(ngModel)]="courseDraft.category")
                                option(value="여행") 여행
                                option(value="데이트") 데이트
                        div(class="course-info-field")
                            span 대표 이미지
                            div(class="course-cover-upload", [class.has-image]="courseDraft.photo")
                                label(class="course-cover-button")
                                    i(class="fa-regular fa-image", aria-hidden="true")
                                    span {{courseDraft.photoName || '사진 첨부'}}
                                    input(type="file", accept="image/*", (change)="onCourseCoverFile($event)")
                                img(*ngIf="courseDraft.photo", [src]="courseDraft.photo", alt="")
                    label(class="course-info-field")
                        span 코스 설명
                        textarea(rows="4", name="course_manual_description", [(ngModel)]="courseDraft.description", placeholder="코스 분위기, 이동 팁, 추천 이유를 적어주세요.")
                    div(class="course-info-options")
                        span(class="course-option-label") 누구와
                        div(class="companion-segment", aria-label="동행 유형")
                            button(type="button", [class.active]="courseDraft.companionType === 'couple'", (click)="setCourseCompanionType('couple')") 연인
                            button(type="button", [class.active]="courseDraft.companionType === 'friend'", (click)="setCourseCompanionType('friend')") 친구
                            button(type="button", [class.active]="courseDraft.companionType === 'solo'", (click)="setCourseCompanionType('solo')") 혼자
                    p(class="course-builder-error", *ngIf="courseBuilderError") {{courseBuilderError}}
                div(class="course-info-actions")
                    button(type="button", class="compose-secondary", (click)="saveCourseDraft()") 임시 저장
                    button(type="button", class="compose-primary", (click)="continueCourseInfo()")
                        span 다음
                        i(class="fa-solid fa-arrow-right", aria-hidden="true")
            nav(class="course-edit-day-tabs", *ngIf="courseComposerPlannerEdit && courseBuilderStep === 'places'", aria-label="수정할 일차 선택")
                button(type="button", *ngFor="let day of courseBuilderDays; let index = index", [class.active]="courseBuilderDayIndex === index", (click)="setCourseBuilderDay(index)")
                    strong {{day.label}}
                    small {{day.places.length}}곳
            div(class="course-builder-fixed", *ngIf="courseBuilderStep === 'places'")
                div(class="course-builder-map", [class.empty]="courseBuilderPlaces.length === 0")
                    div(class="course-google-map", [class.active]="courseGoogleReady")
                    div(class="course-map-fallback", [class.hidden]="courseGoogleReady")
                        div(class="course-draft-map-grid")
                        svg(class="course-draft-route", viewBox="0 0 100 100", preserveAspectRatio="none", aria-hidden="true")
                            polyline(*ngIf="courseTimelineMapSpots().length > 1", [attr.points]="courseTimelineRoutePoints()")
                        span(class="course-draft-pin", *ngFor="let spot of courseTimelineMapSpots(); let index = index", [style.left.%]="spot.x", [style.top.%]="spot.y", [attr.title]="spot.name")
                            em {{index + 1}}
                    div(class="course-map-empty", *ngIf="courseBuilderPlaces.length === 0")
                        i(class="fa-solid fa-map-location-dot", aria-hidden="true")
                        span 첫 장소를 검색해서 담아보세요
                    span(class="course-map-badge region") {{courseRegionLabel()}}
                    span(class="course-map-badge walk") {{courseWalkBadge()}}
                div(class="course-search-shell")
                    div(class="course-search-bar")
                        i(class="fa-solid fa-magnifying-glass", aria-hidden="true")
                        input(type="search", class="course-place-search-input", [(ngModel)]="coursePlaceSearchQuery", placeholder="이 근처 장소 검색해서 담기", (focus)="openCoursePlaceSearch()", (input)="onCoursePlaceSearchInput()", (keyup.enter)="searchCoursePlaces()")
                        button(type="button", aria-label="검색", (click)="searchCoursePlaces()")
                            i(class="fa-solid fa-arrow-right", aria-hidden="true")
                    div(class="course-search-results", *ngIf="coursePlaceSearchOpen")
                        div(class="course-search-state", *ngIf="coursePlaceSearching") 장소 검색 중...
                        button(type="button", *ngFor="let place of coursePlaceSearchResults", (click)="addCoursePlace(place)")
                            span(class="result-main")
                                strong {{place.name}}
                                small {{place.area || place.address || place.category}}
                            span(class="result-meta", *ngIf="place.distance_km !== null && place.distance_km !== undefined") {{place.distance_km}}km
                            i(class="fa-solid fa-plus", aria-hidden="true")
                        div(class="course-search-state", *ngIf="!coursePlaceSearching && coursePlaceSearchResults.length === 0") 검색 결과가 없습니다
            div(class="course-timeline-scroll", *ngIf="courseBuilderStep === 'places'")
                section(class="course-empty-timeline", *ngIf="courseBuilderPlaces.length === 0")
                    i(class="fa-solid fa-location-dot", aria-hidden="true")
                    strong 첫 장소를 검색해서 담아보세요
                    span 지도와 타임라인이 동시에 채워집니다.
                div(class="course-timeline-list", *ngIf="courseBuilderPlaces.length > 0")
                    article(class="course-timeline-card", *ngFor="let place of courseBuilderPlaces; let index = index", draggable="true", (dragstart)="coursePlaceDragStart(index)", (dragover)="coursePlaceDragOver($event)", (drop)="coursePlaceDrop(index)")
                        div(class="timeline-time")
                            input(type="time", [(ngModel)]="place.visitTime", (change)="updateCourseVisitTime(place)", [attr.aria-label]="place.name + ' 방문 시간'")
                        span(class="timeline-number") {{index + 1}}
                        div(class="timeline-copy")
                            strong {{place.name}}
                            small {{place.area || place.address || place.category || '방문 장소'}}
                            input(type="text", [(ngModel)]="place.memo", aria-label="메모", (input)="updateCoursePlaceMemo()")
                            small(class="timeline-distance", *ngIf="index < courseBuilderPlaces.length - 1") {{courseSegmentDistanceLabel(index)}}
                        div(class="timeline-actions")
                            button(type="button", class="drag-handle", aria-label="순서 변경")
                                i(class="fa-solid fa-grip-vertical", aria-hidden="true")
                            button(type="button", class="remove-place", aria-label="삭제", (click)="removeCoursePlace(index)")
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                    button(type="button", class="add-place-dashed", (click)="focusCoursePlaceSearch()")
                        i(class="fa-solid fa-plus", aria-hidden="true")
                        span 지도에서 장소 추가
            div(class="course-action-bar", *ngIf="courseBuilderStep === 'places'")
                p(class="course-builder-error", *ngIf="courseBuilderError") {{courseBuilderError}}
                div(class="course-action-buttons")
                    button(type="button", class="course-step-back", (click)="courseComposerPlannerEdit ? closeCourseComposer() : backToCourseInfo()")
                        i(class="fa-solid", [ngClass]="courseComposerPlannerEdit ? 'fa-xmark' : 'fa-arrow-left'", aria-hidden="true")
                        span {{courseComposerPlannerEdit ? '취소' : '이전'}}
                    button(type="button", class="course-publish-button", *ngIf="!courseComposerPlannerEdit", (click)="openCoursePublishModal()")
                        i(class="fa-solid fa-paper-plane", aria-hidden="true")
                        span 코스 게시하기
                    button(type="button", class="course-publish-button course-edit-complete", *ngIf="courseComposerPlannerEdit", [disabled]="courseAiRebuilding", (click)="completePlannerCourseEdit()")
                        i(class="fa-solid", [ngClass]="courseAiRebuilding ? 'fa-spinner fa-spin' : 'fa-wand-magic-sparkles'", aria-hidden="true")
                        span {{courseAiRebuilding ? 'AI 재구성 중' : '변경 완료'}}

            div(class="course-publish-backdrop", *ngIf="coursePublishModalOpen", (click)="closeCoursePublishModal()")
            section(class="course-publish-modal", *ngIf="coursePublishModalOpen", role="dialog", aria-modal="true", aria-label="코스 게시 설정")
                div(class="publish-modal-head")
                    div
                        span 게시 설정
                        h3 코스 메타 정보
                    button(type="button", aria-label="닫기", (click)="closeCoursePublishModal()")
                        i(class="fa-solid fa-xmark", aria-hidden="true")
                div(class="publish-modal-body")
                    label
                        span 제목
                        input(type="text", [(ngModel)]="courseDraft.title", placeholder="예: 성수 감성 데이트 루트")
                    div(class="publish-grid")
                        label
                            span 카테고리
                            select(name="course_publish_category", [(ngModel)]="courseDraft.category")
                                option(value="여행") 여행
                                option(value="데이트") 데이트
                        label
                            span 대표 지역
                            input(type="text", [(ngModel)]="courseDraft.region", placeholder="서울 성수")
                    div(class="companion-segment", aria-label="동행 유형")
                        button(type="button", [class.active]="courseDraft.companionType === 'couple'", (click)="setCourseCompanionType('couple')") 연인
                        button(type="button", [class.active]="courseDraft.companionType === 'friend'", (click)="setCourseCompanionType('friend')") 친구
                        button(type="button", [class.active]="courseDraft.companionType === 'solo'", (click)="setCourseCompanionType('solo')") 혼자
                    div(class="course-info-field")
                        span 커버 이미지
                        div(class="course-cover-upload", [class.has-image]="courseDraft.photo")
                            label(class="course-cover-button")
                                i(class="fa-regular fa-image", aria-hidden="true")
                                span {{courseDraft.photoName || '사진 첨부'}}
                                input(type="file", accept="image/*", (change)="onCourseCoverFile($event)")
                            img(*ngIf="courseDraft.photo", [src]="courseDraft.photo", alt="")
                    label
                        span 코스 설명
                        textarea(rows="3", [(ngModel)]="courseDraft.description", placeholder="코스 분위기, 이동 팁, 추천 이유를 적어주세요.")
                    button(type="button", class="companion-toggle", [class.active]="courseDraft.companionEnabled", (click)="toggleCourseCompanion()")
                        i(class="fa-solid", [ngClass]="courseDraft.companionEnabled ? 'fa-toggle-on' : 'fa-toggle-off'", aria-hidden="true")
                        span 동행 모집하기
                    div(class="companion-compose-fields", *ngIf="courseDraft.companionEnabled")
                        div(class="companion-course-lock-note")
                            i(class="fa-solid fa-circle-check", aria-hidden="true")
                            span 이 모집은 게시 완료된 확정 코스에만 연결됩니다.
                        div(class="compose-grid")
                            label
                                span 여행 날짜
                                input(type="text", [(ngModel)]="courseDraft.companionDate", placeholder="7.12 토")
                            label
                                span 시작 시간
                                input(type="text", [(ngModel)]="courseDraft.companionTime", placeholder="13:00-18:30")
                            label
                                span 모집 인원
                                input(type="number", min="1", max="8", [(ngModel)]="courseDraft.companionCapacity")
                            label
                                span 예상 비용
                                input(type="text", [(ngModel)]="courseDraft.companionCost", placeholder="1인 약 5만원")
                            label
                                span 여행 속도
                                select(name="course_companion_pace", [(ngModel)]="courseDraft.companionPace")
                                    option(value="") 선택
                                    option(value="slow") 여유롭게
                                    option(value="balanced") 보통
                                    option(value="fast") 빠르게
                            label
                                span 예산 성향
                                select(name="course_companion_budget", [(ngModel)]="courseDraft.companionBudgetStyle")
                                    option(value="") 선택
                                    option(value="low") 알뜰형
                                    option(value="medium") 균형형
                                    option(value="high") 경험 우선
                            label
                                span 흡연 선호
                                select(name="course_companion_smoking", [(ngModel)]="courseDraft.companionSmoking")
                                    option(value="") 선택
                                    option(value="non") 비흡연
                                    option(value="smoking") 흡연
                                    option(value="flexible") 상관없음
                            label
                                span 음주 선호
                                select(name="course_companion_drinking", [(ngModel)]="courseDraft.companionDrinking")
                                    option(value="") 선택
                                    option(value="none") 음주 안 함
                                    option(value="light") 가볍게
                                    option(value="social") 즐기는 편
                                    option(value="flexible") 상관없음
                        label
                            span 선호 분위기
                            input(type="text", [(ngModel)]="courseDraft.companionMood", placeholder="사진, 조용한 대화, 맛집")
                        label
                            span 변경 가능한 일정
                            input(type="text", [(ngModel)]="courseDraft.companionFlexible", placeholder="카페 순서, 종료 시간 ±1시간")
                        label
                            span 약속 장소
                            input(type="text", [(ngModel)]="courseDraft.companionMeetingPoint", placeholder="서울숲역 3번 출구")
                        label
                            span 간단한 소개
                            textarea(rows="2", [(ngModel)]="courseDraft.companionIntro", placeholder="함께할 여행자에게 보여줄 소개를 적어주세요.")
                    p(class="course-builder-error", *ngIf="courseBuilderError") {{courseBuilderError}}
                div(class="publish-modal-actions")
                    button(type="button", class="compose-secondary", (click)="closeCoursePublishModal()") 취소
                    button(type="button", class="compose-primary", [disabled]="coursePublishSubmitting", (click)="submitCoursePublish()") {{coursePublishSubmitting ? '게시 중' : '게시 완료'}}

        div(class="composer-backdrop", *ngIf="communityComposerOpen", (click)="closeCommunityComposer()")
        section(class="course-composer-sheet community-composer-sheet", *ngIf="communityComposerOpen", role="dialog", aria-modal="true", aria-label="커뮤니티 글 작성")
            div(class="composer-sheet-head")
                div
                    span 커뮤니티 작성
                    h2 {{communityDraft.kind === 'question' ? '질문글 올리기' : '글쓰기'}}
                button(type="button", aria-label="닫기", [disabled]="communityPublishSubmitting", (click)="closeCommunityComposer()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")
            form(class="course-compose-form community-compose-form", (submit)="$event.preventDefault(); publishCommunityPost()")
                div(class="community-type-toggle", aria-label="글 종류")
                    button(type="button", [class.active]="communityDraft.kind === 'post'", (click)="setCommunityDraftKind('post')")
                        i(class="fa-regular fa-pen-to-square", aria-hidden="true")
                        span 일반글
                    button(type="button", [class.active]="communityDraft.kind === 'question'", (click)="setCommunityDraftKind('question')")
                        i(class="fa-regular fa-circle-question", aria-hidden="true")
                        span 질문글
                label(*ngIf="communityDraft.kind !== 'question'")
                    span 주제
                    select(name="communityTopic", [(ngModel)]="communityDraft.topic")
                        option(*ngFor="let topic of communityTopics", [value]="topic.key", [disabled]="communityDraft.kind === 'post' && topic.key === 'question'") {{topic.label}}
                label
                    span 제목
                    input(type="text", name="communityTitle", [(ngModel)]="communityDraft.title", placeholder="예: 제주 서쪽 2박 코스 질문")
                label
                    span 본문
                    textarea(name="communityBody", [(ngModel)]="communityDraft.body", rows="5", placeholder="블로그 글처럼 여행 경험, 질문, 팁을 자유롭게 적어주세요.")
                div(class="community-relation-toggle", aria-label="여행지 관련 여부")
                    button(type="button", [class.active]="communityDraft.hasDestination", (click)="setCommunityDraftDestination(true)")
                        i(class="fa-solid fa-location-dot", aria-hidden="true")
                        span 여행지 관련
                    button(type="button", [class.active]="!communityDraft.hasDestination", (click)="setCommunityDraftDestination(false)")
                        i(class="fa-regular fa-message", aria-hidden="true")
                        span 일반 주제
                div(class="compose-grid", *ngIf="communityDraft.hasDestination")
                    label
                        span 여행지
                        input(type="text", name="communityDestination", [(ngModel)]="communityDraft.destination", placeholder="서울 성수, 제주 애월")
                    label
                        span 장소
                        input(type="text", name="communityPlace", [(ngModel)]="communityDraft.place", placeholder="카페, 숙소, 전시관")
                div(class="community-tool-grid")
                    div(class="community-photo-field")
                        span 사진
                        div(class="community-photo-actions")
                            label(class="community-photo-button")
                                input(type="file", accept="image/*", aria-label="사진 첨부", (change)="handleCommunityPhotoUpload($event)")
                                i(class="fa-regular fa-image", aria-hidden="true")
                                span 사진 첨부
                            label(class="community-photo-button")
                                input(type="file", accept="image/*", capture="environment", aria-label="사진 촬영", (change)="handleCommunityPhotoUpload($event)")
                                i(class="fa-solid fa-camera", aria-hidden="true")
                                span 촬영
                        div(class="community-photo-preview", *ngIf="communityDraft.photo")
                            img(*ngIf="communityPhotoIsImage(communityDraft.photo)", [src]="communityDraft.photo", alt="첨부 사진 미리보기")
                            span {{communityDraft.photoName || '첨부 사진'}}
                            button(type="button", aria-label="사진 삭제", (click)="clearCommunityPhoto()")
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                    div(class="community-poll-builder", *ngIf="communityDraft.kind === 'question'")
                        div(class="community-tool-head")
                            span 투표
                            small 질문글에서 선택지를 하나씩 추가하세요.
                        div(class="community-option-list", *ngIf="communityDraftPollOptions().length > 0")
                            div(class="community-option-chip", *ngFor="let option of communityDraftPollOptions()")
                                span {{option}}
                                button(type="button", [attr.aria-label]="option + ' 삭제'", (click)="removeCommunityPollOption(option)")
                                    i(class="fa-solid fa-xmark", aria-hidden="true")
                        div(class="community-option-add")
                            input(type="text", name="communityPollInput", [(ngModel)]="communityDraft.pollInput", placeholder="예: 제주 애월 카페", (keydown)="handleCommunityPollKeydown($event)")
                            button(type="button", aria-label="투표 선택지 추가", (click)="addCommunityPollOption($event)")
                                i(class="fa-solid fa-plus", aria-hidden="true")
                    div(class="community-tag-editor")
                        div(class="community-tool-head")
                            span 태그
                            small #여행지 입력 후 추가하면 태그로 표시됩니다.
                        div(class="community-tag-list", *ngIf="communityDraftTags().length > 0")
                            button(type="button", class="community-tag-chip", *ngFor="let tag of communityDraftTags()", [attr.aria-label]="tag + ' 태그 삭제'", (click)="removeCommunityTag(tag)")
                                span {{'#' + tag}}
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                        div(class="community-option-add")
                            input(type="text", name="communityTagInput", [(ngModel)]="communityDraft.tagInput", placeholder="#여행지", (keydown)="handleCommunityTagKeydown($event)", (blur)="addCommunityTagFromInput($event)")
                            button(type="button", aria-label="태그 추가", (click)="addCommunityTagFromInput($event)")
                                i(class="fa-solid fa-plus", aria-hidden="true")
                div(class="compose-actions")
                    button(type="button", class="compose-secondary", [disabled]="communityPublishSubmitting", (click)="closeCommunityComposer()") 취소
                    button(type="submit", class="compose-primary", [disabled]="communityPublishSubmitting")
                        i(class="fa-solid", [ngClass]="communityPublishSubmitting ? 'fa-spinner fa-spin' : 'fa-paper-plane'", aria-hidden="true")
                        span {{communityPublishSubmitting ? '올리는 중' : '올리기'}}

        div(class="sheet-backdrop", *ngIf="activeFilterKey", (click)="closeFilterSheet()")
        section(class="filter-dialog", *ngIf="activeFilter() as filter", role="dialog", aria-modal="true", [attr.aria-label]="getSheetTitle(filter)")
            div(class="sheet-head", [class.has-back]="shouldShowFilterBack(filter)")
                button(type="button", class="sheet-back-button", *ngIf="shouldShowFilterBack(filter)", aria-label="조건 선택으로 돌아가기", (click)="backToFilterOverview()")
                    i(class="fa-solid fa-chevron-left", aria-hidden="true")
                div(class="sheet-title")
                    span {{filter.label}}
                    h2 {{getSheetTitle(filter)}}
                button(type="button", class="sheet-close-button", aria-label="닫기", (click)="closeFilterSheet()")
                    i(class="fa-solid fa-xmark", aria-hidden="true")

            div(class="sheet-options", *ngIf="filter.key === 'companion'")
                button(type="button", class="sheet-option", *ngFor="let option of filter.options", [class.active]="selectedFilters[filter.key] === option", (click)="selectCondition(filter.key, option)")
                    span {{option}}
                    i(*ngIf="selectedFilters[filter.key] === option", class="fa-solid fa-check", aria-hidden="true")

            div(class="calendar-picker", *ngIf="filter.key === 'schedule'")
                div(class="calendar-nav")
                    button(type="button", aria-label="이전 달", (click)="changeCalendarMonth(-1)")
                        i(class="fa-solid fa-chevron-left", aria-hidden="true")
                    strong {{calendarMonthLabel}}
                    button(type="button", aria-label="다음 달", (click)="changeCalendarMonth(1)")
                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                div(class="calendar-weekdays")
                    span(*ngFor="let weekday of weekdays") {{weekday}}
                div(class="calendar-grid", (pointermove)="previewSchedulePointer($event)", (pointerup)="finishSchedulePointer($event)", (pointerleave)="finishSchedulePointer($event)", (pointercancel)="cancelScheduleDrag()")
                    button(type="button", class="calendar-day", *ngFor="let day of calendarDays", [attr.data-date-key]="day.key", [class.muted]="!day.inMonth", [class.today]="day.isToday", [class.in-range]="isScheduleDayInRange(day)", [class.range-start]="isScheduleRangeStart(day)", [class.range-end]="isScheduleRangeEnd(day)", [class.selected]="isScheduleDaySelected(day)", [attr.aria-label]="day.ariaLabel", (pointerdown)="startScheduleDrag(day, $event)", (click)="selectScheduleDay(day)")
                        span {{day.label}}
                div(class="date-range-summary", *ngIf="selectedFilters.schedule")
                    span 선택
                    strong {{selectedFilters.schedule}}
                    button(type="button", aria-label="날짜 초기화", (click)="clearSchedule()")
                        i(class="fa-solid fa-rotate-left", aria-hidden="true")

            div(class="location-picker", *ngIf="filter.key === 'location'")
                div(class="location-regions")
                    button(type="button", class="location-region-button", *ngFor="let region of locationGroups", [class.active]="selectedLocationRegion === region.name", (click)="selectLocationRegion(region)")
                        span {{region.name}}
                        i(class="fa-solid fa-chevron-right", aria-hidden="true")
                div(class="location-areas")
                    button(type="button", class="location-area-button", *ngFor="let area of activeLocationAreas()", [class.active]="isLocationAreaSelected(area)", (click)="selectLocationArea(area)")
                        span {{area.label}}
                        i(*ngIf="isLocationAreaSelected(area)", class="fa-solid fa-check", aria-hidden="true")

        div(class="map-sheet-backdrop", *ngIf="activeTab === 'map' && mapContentTab === 'map' && selectedMapSpot()", (click)="closeMapSpotSheet()")
        section(class="map-place-sheet", *ngIf="activeTab === 'map' && mapContentTab === 'map' && selectedMapSpot() as spot", role="dialog", aria-modal="true", [attr.aria-label]="spot.name + ' 상세'")
            div(class="place-photo", [ngClass]="spot.photoClass")
                span {{spot.kind}}
            div(class="place-detail")
                div(class="place-head")
                    div
                        span {{spot.order}}번째 코스
                        h2 {{spot.name}}
                    button(type="button", aria-label="닫기", (click)="closeMapSpotSheet()")
                        i(class="fa-solid fa-xmark", aria-hidden="true")
                p {{spot.description}}
                div(class="place-meta")
                    span
                        i(class="fa-solid fa-star", aria-hidden="true")
                        | {{spot.rating}}
                    span
                        i(class="fa-regular fa-clock", aria-hidden="true")
                        | {{spot.hours}}
                    span
                        i(class="fa-solid", [ngClass]="travelMode === 'walk' ? 'fa-person-walking' : 'fa-car-side'", aria-hidden="true")
                        | {{getSpotTravelTime(spot)}}
                button(type="button", class="visit-cta", [class.done]="spot.visited", (click)="toggleVisit(spot, $event)")
                    i(class="fa-solid", [ngClass]="spot.visited ? 'fa-check' : 'fa-location-dot'", aria-hidden="true")
                    span {{spot.visited ? '도착 완료' : '여기 도착했어요'}}
