                                                span(class="map-marker", *ngFor="let stop of plannerStops; let i = index", [style.left]="stop.mapLeft", [style.top]="stop.mapTop") {{i + 1}}
                                                small {{plannerMapLabel}}
                                            div(class="planner-google-map", aria-hidden="true")
                                            button(type="button", class="planner-map-open-button", aria-label="실제 장소 지도 확대 보기", title="지도 확대", (click)="openPlannerMap()")
                                                i(class="fa-solid fa-expand", aria-hidden="true")
                                        div(class="ai-route-stats")
                                            div
                                                i(class="fa-regular fa-clock", aria-hidden="true")
