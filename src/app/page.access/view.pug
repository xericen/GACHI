                                                i(class="fa-solid fa-chevron-right", aria-hidden="true")
                                            button(type="button", class="ai-route-save-button", (click)="confirmPlannerCourse()")
                                                i(class="fa-solid fa-circle-check", aria-hidden="true")
                                                span 코스 확정
                                section(class="planner-companion-panel")
                                    div(class="planner-companion-head")
