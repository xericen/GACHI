                                        div(class="planner-google-map-expanded")
                                    ol(class="planner-map-place-list")
                                        li(*ngFor="let stop of plannerStops; let i = index")
                                            span {{i + 1}}
                                            div
                                                strong {{stop.name}}
                                                small {{stop.area}}
                            form(class="composer ai-planner-composer", (submit)="$event.preventDefault(); send()")
