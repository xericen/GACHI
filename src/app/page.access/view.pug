                                                small(class="route-area")
                                                    i(class="fa-solid fa-location-dot", aria-hidden="true")
                                                    span {{stop.area}}
                                                em {{stop.tag}}
                                                small(class="route-move", *ngIf="i < plannerStops.length - 1")
