div(class="access-shell")
    div(class="app-frame typography-normalized", [class.ai-planner-frame]="activeTab === 'chat' && chatContentTab === 'chat'")
        header(class="app-header")
            button(type="button", class="brand-lockup", aria-label="GACHI 홈", (click)="setTab('home')")
                span(class="brand-mark")
                    img(src="/assets/brand/gachi-logo.png", alt="")
                span(class="brand-copy")
                    strong GACHI
                    small 여행 코스
            nav(class="desktop-primary-nav", aria-label="상단 내비게이션")
                button(type="button", [class.active]="activeTab === 'home' && homeContentTab === 'feed'", (click)="setTab('home'); setHomeContentTab('feed')") 홈
                button(type="button", [class.active]="activeTab === 'home' && homeContentTab === 'courses'", (click)="setTab('home'); setHomeContentTab('courses')") 코스 추천
                button(type="button", [class.active]="activeTab === 'home' && homeContentTab === 'companion'", (click)="setTab('home'); setHomeContentTab('companion')") 동행 모집
                button(type="button", [class.active]="activeTab === 'chat' && chatContentTab === 'chat'", (click)="setTab('chat'); setChatContentTab('chat')") AI 플래너
            div(class="header-actions")
                button(type="button", class="planner-login-button", *ngIf="!isLoggedIn()", (click)="goLogin()") 로그인
                button(type="button", class="icon-button chat-history-toggle header-chat-history-toggle", *ngIf="activeTab === 'chat' && chatContentTab === 'chat'", [class.active]="chatDrawerOpen", aria-label="AI 채팅 기록", (click)="toggleChatDrawer()")
                    i(class="fa-solid", [ngClass]="chatDrawerOpen ? 'fa-xmark' : 'fa-clock-rotate-left'", aria-hidden="true")
                button(type="button", class="icon-button course-draft-archive-button", *ngIf="activeTab === 'chat' && chatContentTab === 'community'", [class.active]="communityArchiveOpen", aria-label="커뮤니티 보관함", (click)="openCommunityArchive()")
                    i(class="fa-solid fa-box-archive", aria-hidden="true")
                button(type="button", class="icon-button profile-shop-button", *ngIf="activeTab === 'my'", aria-label="보관함", (click)="openMyArchive()")
                    i(class="fa-solid fa-store", aria-hidden="true")
                button(type="button", class="icon-button notification-button", aria-label="알림")
                    i(class="fa-regular fa-bell", aria-hidden="true")
                button(type="button", class="icon-button profile-menu-button", *ngIf="activeTab === 'my'", aria-label="메뉴", (click)="closeMyProfile()")
                    i(class="fa-solid fa-bars", aria-hidden="true")

        main(class="app-content", [class.map-fixed-content]="activeTab === 'map'", [class.zenly-fixed-content]="activeTab === 'map' && mapContentTab === 'zenly'")
            section(*ngIf="activeTab === 'home'", class="tab-panel home-panel")
                section(class="home-hero-card")
                    div(class="home-title")
                        div(class="home-title-state")
                            p AI 먼저 추천
                            button(type="button", *ngIf="hasActiveFilters()", aria-label="필터 삭제 후 홈으로 돌아가기", title="필터 삭제", (click)="resetHomeFiltersToRoot()")
                                i(class="fa-solid fa-rotate-left", aria-hidden="true")
                        h1 AI와 먼저 코스를 만들어요
                        span 대화로 초안을 만들고, 확정한 코스로 동행까지 이어보세요
                    div(class="home-hero-actions", aria-label="주요 작업")
                        button(type="button", class="home-primary-action", (click)="openAiPlanner()")
                            i(class="fa-solid fa-wand-magic-sparkles", aria-hidden="true")
                            strong AI와 코스 짜기
                            span 몇 마디로 동선·맛집·동행 조건까지 잡아요
                        button(type="button", (click)="openCourseComposer()")
                            i(class="fa-solid fa-location-dot", aria-hidden="true")
                            strong 직접 코스 다듬기
                            span AI 초안이나 내 장소를 지도에서 수정해요
                        button(type="button", (click)="setHomeContentTab('companion')")
                            i(class="fa-solid fa-user-group", aria-hidden="true")
                            strong 코스 기반 동행
                            span 확정한 일정에 맞는 사람을 찾아요

                section(class="home-choice-section", aria-label="동행 방식 선택")
                    h2 동행 구하기, 어떤 방식이 좋으세요?
                    div(class="home-choice-grid")
                        button(type="button", class="home-choice-card choice-plan", (click)="openCourseComposer()")
                            span J 계획형
                            strong
                                | 여행 가기 전
                                br
                                | 동행 구하기
                            small 코스·이력서 보고 미리 매칭
                            span(class="choice-illustration choice-calendar", aria-hidden="true")
                                svg(viewBox="0 0 44 44", fill="none")
                                    rect(x="6", y="10", width="32", height="26", rx="4", fill="#FBD3D6")
                                    rect(x="6", y="10", width="32", height="8", rx="4", fill="#F4A3A9")
                                    line(x1="14", y1="6", x2="14", y2="14", stroke="#E63946", stroke-width="2.5", stroke-linecap="round")
                                    line(x1="30", y1="6", x2="30", y2="14", stroke="#E63946", stroke-width="2.5", stroke-linecap="round")
                        button(type="button", class="home-choice-card choice-live", (click)="setTab('map')")
                            span P 즉흥형
                            strong
                                | 여행 가서
                                br
                                | 동행 구하기
                            small 현재 위치 기준 짧게 합류
                            span(class="choice-illustration choice-plane", aria-hidden="true")
                                svg(viewBox="0 0 44 44", fill="none")
                                    path(d="M6 22 L38 8 L28 38 L22 24 L6 22Z", fill="#F4A3A9")
                                    path(d="M22 24 L38 8 L22 24Z", fill="#FBD3D6")

                nav(class="home-content-tabs", aria-label="홈 콘텐츠 탭")
                    button(type="button", [class.active]="homeContentTab === 'feed'", (click)="setHomeContentTab('feed')") 추천
                    button(type="button", [class.active]="homeContentTab === 'courses'", (click)="setHomeContentTab('courses')") 코스
                    button(type="button", [class.active]="homeContentTab === 'companion'", (click)="setHomeContentTab('companion')") 동행

                div(class="home-tab-content")
                    section(class="home-feed-content", *ngIf="homeContentTab === 'feed'")
                        section(class="content-section")
                            div(class="section-head")
                                div
                                    p 추천 여행 코스
                                    h2 지금 떠나기 좋은 코스
                                span {{filteredRecommendations().length}}개
                            div(class="recommendation-row")
                                article(class="course-card", *ngFor="let course of filteredRecommendations().slice(0, 6)")
                                    div(class="course-media", [ngClass]="course.tone || 'tone-blue'")
                                        img(*ngIf="course.image && !course.image_broken", [src]="course.image", alt="", (error)="markCourseImageBroken(course)")
                                        i(*ngIf="!course.image || course.image_broken", class="fa-solid", [ngClass]="course.icon", aria-hidden="true")
                                        button(type="button", class="save-button", [class.saved]="course.saved", [attr.aria-label]="course.saved ? '찜 해제' : '찜하기'", (click)="toggleSave(course)")
                                            i(class="fa-heart", [ngClass]="course.saved ? 'fa-solid' : 'fa-regular'", aria-hidden="true")
                                    div(class="course-body")
                                        span(class="course-location") {{course.location}}
                                        h3 {{course.title}}
                                        p {{course.summary}}
                                        div(class="meta-row")
                                            span
                                                i(class="fa-regular fa-clock", aria-hidden="true")
                                                | {{course.duration}}
                                            span
                                                i(class="fa-solid fa-star", aria-hidden="true")
                                                | {{course.rating || '4.7'}}

                        section(class="content-section compact-section")
                            div(class="section-head")
                                div
                                    p 최신 여행 코스
                                    h2 새로 공유된 코스
                                span {{latestCourses().length}}개
                            div(class="course-list")
                                article(class="list-item", *ngFor="let course of latestCourses().slice(0, 3)")
                                    div(class="list-icon")
                                        i(class="fa-solid", [ngClass]="course.icon", aria-hidden="true")
                                    div(class="list-body")
                                        span {{course.location}}
                                        h3 {{course.title}}
                                        p {{course.summary}}
                                    button(type="button", class="save-button inline", [class.saved]="course.saved", [attr.aria-label]="course.saved ? '찜 해제' : '찜하기'", (click)="toggleSave(course)")
                                        i(class="fa-heart", [ngClass]="course.saved ? 'fa-solid' : 'fa-regular'", aria-hidden="true")

                        section(class="companion-preview-section")
                            div(class="section-head")
                                div
                                    p 동행 모집
                                    h2 코스와 연결된 모집글
                                span {{filteredCompanionPosts().length}}개
                            article(class="companion-card", *ngFor="let post of filteredCompanionPosts().slice(0, 2)")
                                div(class="companion-card-head")
                                    div
                                        span {{post.location}} · {{post.date}}
                                        h3 {{post.title}}
                                    button(type="button", [class.saved]="post.saved", aria-label="동행 글 저장", (click)="toggleCompanionSave(post, $event)")
                                        i(class="fa-bookmark", [ngClass]="post.saved ? 'fa-solid' : 'fa-regular'", aria-hidden="true")
                                p {{post.intro}}
                                div(class="companion-meta")
                                    span
                                        i(class="fa-solid fa-route", aria-hidden="true")
                                        | {{post.route}}
                                    span
                                        i(class="fa-solid fa-user-group", aria-hidden="true")
                                        | {{companionApplicantCount(post)}}/{{post.capacity}}명
                                div(class="companion-actions")
                                    em {{companionStatusLabel(post)}}
                                    button(type="button", [disabled]="post.status === 'requested'", (click)="requestCompanion(post)") {{companionActionLabel(post)}}
                            div(class="empty-state", *ngIf="filteredCompanionPosts().length === 0")
                                i(class="fa-regular fa-comments", aria-hidden="true")
                                p {{homeRegionLabel()}} 동행 모집글이 없습니다. 필터를 삭제하면 메인 홈으로 돌아갑니다.

                    section(class="home-courses-content", *ngIf="homeContentTab === 'courses'")
                        label(class="search-bar")
                            i(class="fa-solid fa-magnifying-glass", aria-hidden="true")
                            input(type="search", [(ngModel)]="query", name="courseSearch", placeholder="지역, 테마, 코스명 검색", aria-label="여행 코스 검색", (input)="handleSearchInput()")
                            button(type="button", class="clear-button", *ngIf="query", aria-label="검색어 지우기", (click)="clearSearch()")
                                i(class="fa-solid fa-xmark", aria-hidden="true")
                        div(class="filter-controls")
                            div(class="keyword-row", aria-label="여행 키워드")
                                button(type="button", class="keyword-pill", *ngFor="let tag of keywordTags", [class.selected]="selectedKeyword === tag", (click)="toggleKeyword(tag)") {{tag}}
                            div(class="condition-row", [class.has-reset]="hasActiveFilters()")
                                button(type="button", class="condition-button", *ngFor="let filter of conditionFilters", [class.filled]="isConditionSelected(filter.key)", (click)="openFilterSheet(filter.key)")
                                    i(class="fa-solid", [ngClass]="filter.icon", aria-hidden="true")
                                    span {{getConditionText(filter)}}
                                    i(class="fa-solid fa-chevron-down", aria-hidden="true")
                                button(type="button", class="filter-reset-button", *ngIf="hasActiveFilters()", aria-label="필터 초기화", (click)="clearAllFilters()")
                                    i(class="fa-solid fa-rotate-left", aria-hidden="true")
                        section(class="content-section")
                            div(class="section-head")
                                div
                                    p 인기 여행 코스
                                    h2 저장이 많은 코스
                                span {{filteredRecommendations().length}}개
                            div(class="recommendation-row")
                                article(class="course-card", *ngFor="let course of filteredRecommendations()")
                                    div(class="course-media", [ngClass]="course.tone || 'tone-blue'")
                                        img(*ngIf="course.image && !course.image_broken", [src]="course.image", alt="", (error)="markCourseImageBroken(course)")
                                        i(*ngIf="!course.image || course.image_broken", class="fa-solid", [ngClass]="course.icon", aria-hidden="true")
                                        button(type="button", class="save-button", [class.saved]="course.saved", [attr.aria-label]="course.saved ? '찜 해제' : '찜하기'", (click)="toggleSave(course)")
                                            i(class="fa-heart", [ngClass]="course.saved ? 'fa-solid' : 'fa-regular'", aria-hidden="true")
                                    div(class="course-body")
                                        span(class="course-location") {{course.location}}
                                        h3 {{course.title}}
                                        p {{course.summary}}
                                        div(class="meta-row")
                                            span
                                                i(class="fa-regular fa-clock", aria-hidden="true")
                                                | {{course.duration}}
                                            span
                                                i(class="fa-solid fa-star", aria-hidden="true")
                                                | {{course.rating || '4.7'}}
                        section(class="content-section")
                            div(class="section-head")
                                div
                                    p 최신 여행 코스
                                    h2 사용자가 만든 코스
                                span {{filteredCourses().length}}개
                            div(class="course-list")
                                article(class="list-item", *ngFor="let course of filteredCourses()")
                                    div(class="list-icon", [class.has-image]="course.image && !course.image_broken")
                                        img(*ngIf="course.image && !course.image_broken", [src]="course.image", alt="", (error)="markCourseImageBroken(course)")
                                        i(*ngIf="!course.image || course.image_broken", class="fa-solid", [ngClass]="course.icon", aria-hidden="true")
                                    div(class="list-body")
                                        span {{course.location}}
                                        h3 {{course.title}}
                                        p {{course.summary}}
                                    button(type="button", class="save-button inline", [class.saved]="course.saved", [attr.aria-label]="course.saved ? '찜 해제' : '찜하기'", (click)="toggleSave(course)")
                                        i(class="fa-heart", [ngClass]="course.saved ? 'fa-solid' : 'fa-regular'", aria-hidden="true")

                    section(class="home-companion-content", *ngIf="homeContentTab === 'companion'")
                        div(class="companion-flow-card")
                            strong 동행은 여행 코스와 연결됩니다
                            p 신청할 때 여행 이력서가 함께 제출되고, 작성자는 이력서를 확인한 뒤 동행을 선택합니다.
                        div(class="companion-list")
                            article(class="companion-card", *ngFor="let post of filteredCompanionPosts()")
                                div(class="companion-card-head")
                                    div
                                        span {{post.location}} · {{post.date}}
                                        h3 {{post.title}}
                                    button(type="button", [class.saved]="post.saved", aria-label="동행 글 저장", (click)="toggleCompanionSave(post, $event)")
                                        i(class="fa-bookmark", [ngClass]="post.saved ? 'fa-solid' : 'fa-regular'", aria-hidden="true")
                                p {{post.intro}}
                                div(class="companion-meta")
                                    span
                                        i(class="fa-solid fa-route", aria-hidden="true")
                                        | {{post.route}}
                                    span
                                        i(class="fa-solid fa-user-group", aria-hidden="true")
                                        | {{companionApplicantCount(post)}}/{{post.capacity}}명
                                    span
                                        i(class="fa-solid fa-user", aria-hidden="true")
                                        | {{post.host}}
                                div(class="companion-actions")
                                    em {{companionStatusLabel(post)}}
                                    button(type="button", [disabled]="post.status === 'requested'", (click)="requestCompanion(post)") {{companionActionLabel(post)}}
                                div(class="companion-application-panel", *ngIf="companionApplications(post).length > 0")
                                    div(class="application-panel-head")
                                        strong 제출된 이력서
                                        span {{companionApplications(post).length}}명
                                    div(class="application-list")
                                        div(class="application-item", *ngFor="let application of companionApplications(post)")
                                            span(class="application-avatar", [class.has-photo]="!!companionApplicationPhoto(application)")
                                                img(*ngIf="companionApplicationPhoto(application)", [src]="companionApplicationPhoto(application)", alt="신청자 사진")
                                                i(*ngIf="!companionApplicationPhoto(application)", class="fa-regular fa-user", aria-hidden="true")
                                            div(class="application-body")
                                                div(class="application-title-row")
                                                    strong {{companionApplicationName(application)}}
                                                    em(class="application-status", [class.accepted]="application.status === 'accepted'") {{companionApplicationStatusLabel(application)}}
                                                span {{companionApplicationMeta(application)}}
                                                p {{companionApplicationIntro(application)}}
                                                small {{companionApplicationExperience(application)}}
                                            button(type="button", class="application-select-button", *ngIf="application.status !== 'accepted'", [attr.aria-label]="companionApplicationName(application) + ' 선택'", (click)="acceptCompanionApplication(post, application)") 선택
                            div(class="empty-state", *ngIf="filteredCompanionPosts().length === 0")
                                i(class="fa-regular fa-comments", aria-hidden="true")
                                p {{homeRegionLabel()}} 동행 모집글이 없습니다.

            section(*ngIf="activeTab === 'chat'", class="tab-panel chat-panel")
                nav(class="chat-content-tabs", aria-label="AI 채팅 콘텐츠 탭")
                    button(type="button", [class.active]="chatContentTab === 'chat'", (click)="setChatContentTab('chat')") AI 채팅
                    button(type="button", [class.active]="chatContentTab === 'community'", (click)="setChatContentTab('community')") 커뮤니티
                    button(type="button", [class.active]="chatContentTab === 'dm'", (click)="setChatContentTab('dm')") 1:1 채팅

                div(class="chat-tab-content")
                    section(class="chat-conversation-content", *ngIf="chatContentTab === 'chat'")
                        div(class="ai-planner-layout")
                            section(class="ai-planner-chat-card", aria-label="GACHI AI 트래블 코치")
                                div(class="ai-planner-card-head")
                                    button(type="button", class="ai-chat-back-button", aria-label="홈으로 돌아가기", (click)="setTab('home')")
                                        i(class="fa-solid fa-chevron-left", aria-hidden="true")
                                    span(class="ai-chat-logo", aria-hidden="true")
                                        img(src="/assets/brand/gachi-logo.png", alt="")
                                    div(class="ai-chat-title")
                                        strong GACHI AI
                                    button(type="button", class="ai-chat-more-button", [class.active]="chatDrawerOpen", aria-label="AI 채팅 보관함", (click)="toggleChatDrawer()")
                                        i(class="fa-solid fa-ellipsis", aria-hidden="true")
                                button(type="button", class="chat-history-backdrop", *ngIf="chatDrawerOpen", aria-label="AI 채팅 보관함 닫기", (click)="toggleChatDrawer()")
                                aside(class="chat-history-drawer chat-history-side-panel", [class.open]="chatDrawerOpen", role="dialog", aria-label="AI 채팅 보관함", [attr.aria-hidden]="!chatDrawerOpen")
                                    div(class="chat-history-head")
                                        button(type="button", class="chat-history-back-button", aria-label="채팅으로 돌아가기", (click)="toggleChatDrawer()")
                                            i(class="fa-solid fa-chevron-left", aria-hidden="true")
                                        strong AI 채팅 보관함
                                        button(type="button", class="chat-new-button", (click)="startNewChat()")
                                            i(class="fa-solid fa-pen-to-square", aria-hidden="true")
                                            span 새 AI 채팅
                                    div(class="chat-history-state", *ngIf="!isLoggedIn()")
                                        p 로그인하면 AI와 나눈 대화가 저장됩니다.
                                        button(type="button", (click)="goChatLogin()") 로그인하기
                                    div(class="chat-history-state", *ngIf="isLoggedIn() && chatHistoryLoading")
                                        i(class="fa-solid fa-spinner fa-spin", aria-hidden="true")
                                        p 불러오는 중
                                    div(class="chat-history-state", *ngIf="isLoggedIn() && !chatHistoryLoading && chatThreads.length === 0")
                                        p 아직 저장된 대화가 없습니다.
                                    div(class="chat-thread-list", *ngIf="isLoggedIn() && !chatHistoryLoading && chatThreads.length > 0")
                                        button(type="button", class="chat-thread-item", *ngFor="let thread of chatThreads", [class.active]="thread.id === activeChatThreadId", (click)="openChatThread(thread)")
                                            strong {{thread.title}}
                                            small {{thread.preview || '대화를 다시 열어보세요.'}}
                                div(class="message-list ai-planner-message-list")
                                    article(class="message", *ngFor="let message of messages", [class.user]="message.role === 'user'", [class.assistant]="message.role === 'assistant'", [class.loading]="message.loading")
                                        div(class="avatar")
                                            img(src="/assets/brand/gachi-logo.png", alt="")
                                        p([innerHTML]="formatMessage(message.text)")
                                        small(class="message-meta")
                                            span {{message.time || (message.role === 'user' ? '방금' : '오전 10:30')}}
                                            i(class="fa-solid fa-check-double", *ngIf="message.role === 'user'", aria-hidden="true")
                            section(class="ai-planner-preview ai-planner-building", *ngIf="isPlannerGenerating && !plannerCourseReady", aria-live="polite")
                                div(class="ai-building-head")
                                    i(class="fa-solid fa-spinner fa-spin", aria-hidden="true")
                                    div
                                        strong 실시간 코스 생성 중
                                        small AI가 대화 내용을 읽고 실제 장소 후보와 동선을 맞추고 있어요
                                div(class="ai-building-steps")
                                    span
                                    span
                                    span
                            section(class="ai-planner-preview", *ngIf="plannerCourseReady", aria-label="실시간 여행 코스", (touchstart)="handlePlannerTouchStart($event)", (touchend)="handlePlannerTouchEnd($event)")
                                div(class="ai-preview-head")
                                    div
                                        span ✨ 실시간 코스
                                        h2 {{plannerCourseTitle}}
                                        em(class="course-day-label", *ngIf="hasPlannerMultipleDays()") {{plannerActiveDayLabel()}}
                                        small {{plannerRouteSource}} · 대화에 맞춰 실시간으로 코스가 완성돼요
                                    button(type="button", class="route-edit-button", (click)="openPlannerCourseEditor()")
                                        i(class="fa-regular fa-pen-to-square", aria-hidden="true")
                                        | 코스 수정하기
                                div(class="planner-live-status", *ngIf="isPlannerGenerating", aria-live="polite")
                                    i(class="fa-solid fa-spinner fa-spin", aria-hidden="true")
                                    span AI가 방금 대화를 반영해 코스를 업데이트하고 있어요
                                div(class="ai-itinerary-body")
                                    div(class="ai-route-flow")
