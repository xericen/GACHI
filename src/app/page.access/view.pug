                                    small {{activeCommunityPost.author || '여행자'}} · {{activeCommunityPost.createdLabel || '방금'}}
                            div(class="community-detail-body")
                                p(class="community-detail-summary") {{activeCommunityPost.summary}}
                                div(class="community-photo-note community-detail-photo", *ngIf="activeCommunityPost.photo", [class.has-image]="communityPhotoIsImage(activeCommunityPost.photo)")
                                    img(*ngIf="communityPhotoIsImage(activeCommunityPost.photo)", [src]="activeCommunityPost.photo", alt="첨부 사진")
                                    div
                                        i(class="fa-regular fa-image", aria-hidden="true")
                                        span {{communityPhotoLabel(activeCommunityPost)}}
                                div(class="community-poll", *ngIf="activeCommunityPost.poll")
                                    div(class="community-poll-head")
