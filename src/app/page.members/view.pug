nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-5xl px-2 sm:px-4 lg:px-8 py-3 lg:px-6")
        div(class="flex items-center justify-between")
            div(class="min-w-0 flex-1")
                h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z")
                    span 멤버

            div(class="flex items-center gap-2")
                button(
                    (click)="openInvite()",
                    class="inline-flex items-center rounded-xl bg-red-600 px-3 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 mr-1")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z")
                    span 초대

div(class="max-w-5xl pt-4 px-8 mb-6")
    //- Role Filter
    div(class="flex flex-wrap items-center gap-2 mb-4")
        span(class="text-xs text-gray-400 mr-1") 역할:
        button(
            (click)="filterByRole('')",
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors",
            [ngClass]="search.role === '' ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'")
            | 전체
        button(
            *ngFor="let role of roles",
            (click)="filterByRole(role)",
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium capitalize transition-colors",
            [ngClass]="search.role === role ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'")
            | {{role}}

    //- Members Grid
    ng-container(*ngIf="loading")
        div(class="text-center py-12 text-[13px] text-gray-400") 로딩 중...

    ng-container(*ngIf="!loading")
        div(*ngIf="members.length === 0", class="text-center py-12 text-[13px] text-gray-400") 멤버가 없습니다.

        div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4", *ngIf="members.length > 0")
            div(*ngFor="let member of members", class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-shadow")
                div(class="flex items-start justify-between")
                    div(class="flex items-center gap-3")
                        div(class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full text-sm font-bold", [ngClass]="member.avatarColor || 'bg-red-100 text-red-700'")
                            | {{member.name?.charAt(0) || '?'}}
                        div(class="min-w-0")
                            p(class="text-[13px] font-semibold text-gray-900 truncate") {{member.name}}
                            p(class="text-[11px] text-gray-400 truncate") {{member.email}}

                    span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium capitalize", [ngClass]="roleClass(member.role)")
                        | {{member.role}}

                div(class="mt-4 pt-3 border-t border-gray-100 flex items-center justify-between")
                    span(class="text-[11px] text-gray-400") 가입일: {{member.joined}}
                    button(
                        (click)="removeMember(member); $event.stopPropagation()",
                        class="text-[11px] text-gray-400 hover:text-red-500 transition-colors")
                        | 제거

//- Invite Modal
div(*ngIf="showInviteModal", class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm")
    div(class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4 overflow-hidden")
        div(class="px-6 py-5 border-b border-gray-100")
            h3(class="text-[15px] font-semibold text-gray-900") 멤버 초대
            p(class="text-[13px] text-gray-500 mt-1") 이메일 주소로 새 멤버를 초대합니다.

        div(class="px-6 py-6 space-y-4")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 이메일
                input(
                    type="email",
                    [(ngModel)]="inviteData.email",
                    placeholder="name@example.com",
                    class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 역할
                select(
                    [(ngModel)]="inviteData.role",
                    class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")
                    option(value="viewer") Viewer
                    option(value="editor") Editor
                    option(value="admin") Admin

        div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-2")
            button(
                (click)="showInviteModal = false",
                class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-[13px] font-medium text-gray-700 shadow-sm hover:bg-gray-50") 취소
            button(
                (click)="invite()",
                class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500") 초대
