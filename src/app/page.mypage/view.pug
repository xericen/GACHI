nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-3xl px-2 sm:px-4 lg:px-8 py-3 lg:px-6")
        div(class="flex items-center justify-between")
            div(class="min-w-0 flex-1")
                h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z")
                    span 내 프로필

ng-container(*ngIf="user")
    div(class="max-w-3xl pt-8 px-8 pb-12 space-y-8")
        //- Profile Section
        div(class="bg-white rounded-xl border border-gray-200 overflow-hidden")
            div(class="px-6 py-5 border-b border-gray-100")
                h2(class="text-[15px] font-semibold text-gray-900") 개인정보
                p(class="mt-1 text-[13px] text-gray-500") 기본 프로필 정보를 수정할 수 있습니다.

            div(class="px-6 py-6 space-y-5")
                //- Avatar
                div(class="flex items-center gap-x-4 pb-2")
                    div(class="flex items-center justify-center w-14 h-14 rounded-full bg-red-100 text-red-600 text-xl font-bold")
                        | {{user.name?.charAt(0) || '?'}}
                    div
                        p(class="text-[13px] font-medium text-gray-900") {{user.name}}
                        p(class="text-[13px] text-gray-500") {{user.email}}
                        span(class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium mt-1",
                            [ngClass]="user.role === 'admin' ? 'bg-purple-100 text-purple-700' : 'bg-red-100 text-red-700'")
                            | {{user.role}}

                //- Email (readonly)
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 이메일
                    input(type="email", [value]="user.email", disabled, class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-[13px] text-gray-500")

                //- Name
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 이름
                    input(type="text", [(ngModel)]="user.name", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

                //- Mobile
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 연락처
                    input(type="text", [(ngModel)]="user.mobile", placeholder="010-0000-0000", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

            div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end")
                button(
                    (click)="updateProfile()",
                    [disabled]="saving",
                    class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500 disabled:opacity-50")
                    svg(class="animate-spin size-4 mr-2", viewBox="0 0 24 24", *ngIf="saving")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                    | 저장

        //- Password Section
        div(class="bg-white rounded-xl border border-gray-200 overflow-hidden")
            div(class="px-6 py-5 border-b border-gray-100")
                h2(class="text-[15px] font-semibold text-gray-900") 비밀번호 변경
                p(class="mt-1 text-[13px] text-gray-500") 보안을 위해 주기적으로 비밀번호를 변경해주세요.

            div(class="px-6 py-6 space-y-5")
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 현재 비밀번호
                    input(type="password", [(ngModel)]="passwordForm.current_password", placeholder="현재 비밀번호 입력", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 새 비밀번호
                    input(type="password", [(ngModel)]="passwordForm.new_password", placeholder="8자 이상 입력", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 새 비밀번호 확인
                    input(type="password", [(ngModel)]="passwordForm.confirm_password", placeholder="새 비밀번호 다시 입력", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

            div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end")
                button(
                    (click)="changePassword()",
                    [disabled]="changingPassword",
                    class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500 disabled:opacity-50")
                    svg(class="animate-spin size-4 mr-2", viewBox="0 0 24 24", *ngIf="changingPassword")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                    | 비밀번호 변경
