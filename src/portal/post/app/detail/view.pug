//- Header with back button and tabs
nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-4xl px-2 sm:px-4 lg:px-8 py-3 lg:px-6")
        div(class="flex items-center justify-between")
            div(class="flex items-center gap-3")
                button(routerLink="/posts", class="flex items-center justify-center w-8 h-8 rounded-lg hover:bg-gray-100 transition-colors")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 text-gray-500")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18")
                h1(class="text-lg font-semibold text-zinc-950")
                    span(*ngIf="isNewPost()") 새 글 작성
                    span(*ngIf="!isNewPost() && data") {{data.title}}
                    span(*ngIf="!isNewPost() && !data") 로딩 중...

    //- Tab Navigation
    div(class="max-w-4xl px-4 lg:px-8", *ngIf="!isNewPost()")
        div(class="flex gap-0 border-b border-gray-200")
            a(
                *ngFor="let t of tabs",
                routerLink="/posts/{{id}}/{{t.key}}",
                class="px-4 py-2.5 text-[13px] font-medium border-b-2 transition-colors -mb-px cursor-pointer",
                [ngClass]="tab === t.key ? 'border-red-600 text-red-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'")
                | {{t.icon}} {{t.label}}

//- Content Area
ng-container(*ngIf="data")
    div(class="max-w-4xl pt-6 px-8 pb-8")

        //- View Tab
        ng-container(*ngIf="tab === 'view'")
            div(class="bg-white rounded-xl border border-gray-200 overflow-hidden")
                div(class="px-6 py-5 border-b border-gray-100")
                    div(class="flex items-center gap-3 mb-3")
                        span(class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800", *ngIf="data.category") {{data.category}}
                        span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium",
                            [ngClass]="data.status === 'published' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-yellow-50 text-yellow-700 border border-yellow-200'")
                            | {{data.status}}
                    h2(class="text-xl font-bold text-gray-900") {{data.title}}
                    div(class="flex items-center gap-3 mt-3 text-[13px] text-gray-500")
                        div(class="flex items-center gap-2")
                            div(class="flex items-center justify-center w-6 h-6 rounded-full bg-red-100 text-red-700 text-[10px] font-bold")
                                | {{data.author?.charAt(0) || '?'}}
                            span {{data.author}}
                        span · {{data.created}}

                div(class="px-6 py-6")
                    div(class="prose prose-sm max-w-none text-[13px] text-gray-700 leading-relaxed whitespace-pre-wrap") {{data.content}}

        //- Edit Tab
        ng-container(*ngIf="tab === 'edit'")
            div(class="bg-white rounded-xl border border-gray-200 overflow-hidden")
                div(class="px-6 py-5 border-b border-gray-100")
                    h2(class="text-[15px] font-semibold text-gray-900")
                        span(*ngIf="isNewPost()") 새 글 작성
                        span(*ngIf="!isNewPost()") 게시물 수정

                div(class="px-6 py-6 space-y-5")
                    div
                        label(class="block text-[13px] font-medium text-gray-700 mb-1") 제목
                        input(
                            type="text",
                            [(ngModel)]="data.title",
                            placeholder="게시물 제목을 입력하세요",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")

                    div
                        label(class="block text-[13px] font-medium text-gray-700 mb-1") 카테고리
                        select(
                            [(ngModel)]="data.category",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")
                            option(value="") 카테고리 선택
                            option(value="공지사항") 공지사항
                            option(value="가이드") 가이드
                            option(value="기술 블로그") 기술 블로그
                            option(value="회의록") 회의록
                            option(value="자유게시판") 자유게시판

                    div
                        label(class="block text-[13px] font-medium text-gray-700 mb-1") 내용
                        textarea(
                            [(ngModel)]="data.content",
                            rows="12",
                            placeholder="내용을 입력하세요...",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none resize-none")

                div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-2")
                    button(routerLink="/posts", class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-[13px] font-medium text-gray-700 shadow-sm hover:bg-gray-50") 취소
                    button(
                        (click)="save()",
                        [disabled]="saving",
                        class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500 disabled:opacity-50")
                        svg(class="animate-spin size-4 mr-2", viewBox="0 0 24 24", *ngIf="saving")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        | 저장

        //- Settings Tab
        ng-container(*ngIf="tab === 'settings'")
            div(class="bg-white rounded-xl border border-gray-200 overflow-hidden")
                div(class="px-6 py-5 border-b border-gray-100")
                    h2(class="text-[15px] font-semibold text-gray-900") 게시물 설정

                div(class="px-6 py-6 space-y-5")
                    div
                        label(class="block text-[13px] font-medium text-gray-700 mb-1") 공개 상태
                        select(
                            [(ngModel)]="data.status",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 focus:outline-none")
                            option(value="draft") 임시저장
                            option(value="published") 공개
                            option(value="archived") 보관

                    //- Meta info (readonly)
                    div(class="border-t border-gray-200 pt-5")
                        h3(class="text-[13px] font-semibold text-gray-900 mb-3") 메타 정보
                        div(class="space-y-3")
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500") 게시물 ID
                                span(class="font-mono text-gray-900") {{data.id}}
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500") 작성자
                                span(class="text-gray-900") {{data.author}}
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500") 작성일
                                span(class="text-gray-900") {{data.created}}
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500") 수정일
                                span(class="text-gray-900") {{data.updated || '-'}}

                div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between")
                    button(
                        (click)="remove()",
                        class="inline-flex items-center rounded-lg border border-red-300 bg-white px-4 py-2 text-[13px] font-medium text-red-600 shadow-sm hover:bg-red-50")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 mr-1")
                            path(stroke-linecap="round", stroke-linejoin="round", d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0")
                        | 삭제
                    button(
                        (click)="save()",
                        [disabled]="saving",
                        class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500 disabled:opacity-50")
                        | 설정 저장

//- Loading State
ng-container(*ngIf="!data && !isNewPost()")
    div(class="max-w-4xl pt-6 px-8 pb-8")
        div(class="flex justify-center py-12")
            p(class="text-[13px] text-gray-400") 로딩 중...
