nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-6xl px-2 sm:px-4 lg:px-8 py-3 lg:px-6")
        div(class="flex items-center justify-between")
            div(class="min-w-0 flex-1")
                h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z")
                    span 게시물

            div(class="flex items-center gap-2")
                //- Search Input
                div(class="w-56 flex rounded-lg ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-inset focus-within:ring-red-600")
                    input(
                        type="text",
                        placeholder="검색어 입력...",
                        (keyup)="searchAction()",
                        [(ngModel)]="search.text",
                        class="block w-full flex-1 border-0 bg-transparent py-1.5 px-3 text-gray-900 placeholder:text-gray-400 focus:ring-0 text-[13px] leading-6")

                button(routerLink="/posts/new/edit", class="inline-flex items-center rounded-xl bg-red-600 px-3 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 mr-1")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M12 4.5v15m7.5-7.5h-15")
                    span 새 글 작성

div(class="max-w-6xl pt-4 px-8 mb-6")
    //- Category Filter Tags
    div(class="flex flex-wrap items-center gap-2 mb-4", *ngIf="categories.length > 0")
        span(class="text-xs text-gray-400 mr-1") 카테고리:
        button(
            (click)="selectCategory('')",
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors",
            [ngClass]="selectedCategory === '' ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'")
            | 전체
        button(
            *ngFor="let cat of categories",
            (click)="selectCategory(cat)",
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors",
            [ngClass]="selectedCategory === cat ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'")
            | {{cat}}

    //- Active filter badge
    div(class="flex flex-wrap items-center gap-2 mb-3", *ngIf="selectedCategory")
        span(class="text-xs text-gray-400") 필터:
        span(class="inline-flex items-center gap-1 rounded-full bg-red-50 border border-red-200 px-2.5 py-0.5 text-xs font-medium text-red-700")
            | {{selectedCategory}}
            button((click)="selectCategory('')", class="ml-0.5 hover:text-red-900")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M6 18 18 6M6 6l12 12")

    //- Table
    div(class="overflow-x-auto shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg")
        table(class="w-full divide-y divide-gray-300")
            thead(class="bg-gray-50")
                tr
                    th(class="px-3 py-3 whitespace-nowrap text-left text-[13px] font-semibold text-gray-900") 카테고리
                    th(class="px-3 py-3 whitespace-nowrap text-left text-[13px] font-semibold text-gray-900") 제목
                    th(class="px-3 py-3 whitespace-nowrap text-left text-[13px] font-semibold text-gray-900") 작성자
                    th(class="px-3 py-3 whitespace-nowrap text-left text-[13px] font-semibold text-gray-900") 상태
                    th(class="px-3 py-3 whitespace-nowrap text-left text-[13px] font-semibold text-gray-900") 작성일

            tbody(class="divide-y divide-gray-200 bg-white")
                ng-container(*ngIf="loading")
                    tr
                        td(class="whitespace-nowrap px-3 py-3 text-[13px] text-gray-500 text-center", colspan="5") 로딩 중...

                ng-container(*ngIf="!loading")
                    tr(*ngIf="list.length === 0")
                        td(class="whitespace-nowrap px-3 py-3 text-[13px] text-gray-500 text-center", colspan="5") 게시물이 없습니다.

                    ng-container(*ngIf="list.length > 0")
                        tr(class="cursor-pointer hover:bg-red-50 transition-colors", *ngFor="let item of list", routerLink="/posts/{{item.id}}/view")
                            td(class="w-1 whitespace-nowrap px-3 py-2.5 text-[13px]")
                                span(class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800", *ngIf="item.category") {{item.category}}
                            td(class="px-3 py-2.5")
                                div(class="text-[13px] font-medium text-gray-900 truncate max-w-md") {{item.title}}
                                div(class="text-[11px] text-gray-400 mt-0.5 truncate max-w-md", *ngIf="item.summary") {{item.summary}}
                            td(class="w-1 whitespace-nowrap px-3 py-2.5 text-[13px] text-gray-500")
                                div(class="flex items-center gap-2")
                                    div(class="flex-shrink-0 flex items-center justify-center w-6 h-6 rounded-full bg-red-100 text-red-700 text-[10px] font-bold")
                                        | {{item.author?.charAt(0) || '?'}}
                                    span {{item.author}}
                            td(class="w-1 whitespace-nowrap px-3 py-2.5 text-[13px]")
                                span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium", [ngClass]="statusClass(item.status)")
                                    | {{item.status}}
                            td(class="w-1 whitespace-nowrap px-3 py-2.5 text-[13px] text-gray-500") {{item.created}}

    //- Pagination
    .px-4.pb-4(*ngIf="pagination.start > 0")
        wiz-portal-season-pagination(
            [current]="pagination.current",
            [start]="pagination.start",
            [end]="pagination.end",
            (pageMove)="load($event)")
